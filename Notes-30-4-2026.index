                    const wheelMat = new THREE.MeshStandardMaterial({color: 0x111111});
                    const wheel1 = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 2.6, 16), wheelMat); wheel1.rotation.z = Math.PI/2; wheel1.position.set(0, 0.4, 1.5);
                    const wheel2 = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 2.6, 16), wheelMat); wheel2.rotation.z = Math.PI/2; wheel2.position.set(0, 0.4, -1.5);
                    const light1 = new THREE.Mesh(new THREE.CircleGeometry(0.3, 16), new THREE.MeshBasicMaterial({color: 0xffffff})); light1.position.set(0.8, 1.5, 2.51);
                    const light2 = new THREE.Mesh(new THREE.CircleGeometry(0.3, 16), new THREE.MeshBasicMaterial({color: 0xffffff})); light2.position.set(-0.8, 1.5, 2.51);
                    cartGroup.add(body, wheel1, wheel2, light1, light2); obsGroup.userData = { isCar: true, speed: 0.5 }; obsGroup.add(cartGroup);
                } else if (type === 4) {
                    const rubble = new THREE.Mesh(new THREE.DodecahedronGeometry(1.4), new THREE.MeshStandardMaterial({ color: 0x444444, roughness: 1 })); rubble.scale.y = 0.1; rubble.position.y = 0.05;
                    const railPiece = new THREE.Mesh(new THREE.BoxGeometry(0.2, 0.2, 2), new THREE.MeshStandardMaterial({color: 0xaaaaaa})); railPiece.position.set(0.5, 0.2, 0); railPiece.rotation.y = 0.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 0.5, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25;
                    obsGroup.add(rubble, railPiece, hitbox); obsGroup.userData.isSlow = true;
                } else if (type === 5) {
                    const trainGroup = new THREE.Group();
                    const body = new THREE.Mesh(new THREE.BoxGeometry(2.8, 3.5, 10), new THREE.MeshStandardMaterial({color: 0x1a3b5c, roughness: 0.5, metalness: 0.3})); body.position.y = 2.25;
                    const stripe = new THREE.Mesh(new THREE.BoxGeometry(2.85, 0.3, 10.05), new THREE.MeshStandardMaterial({color: 0xeeeeee})); stripe.position.y = 1.8;
                    const glass = new THREE.Mesh(new THREE.PlaneGeometry(2.4, 1.2), new THREE.MeshBasicMaterial({color: 0x111111})); glass.position.set(0, 3, 5.01);
                    const lightL = new THREE.Mesh(new THREE.CircleGeometry(0.3, 16), new THREE.MeshBasicMaterial({color: 0xffffff})); lightL.position.set(-0.8, 1.5, 5.01);
                    const lightR = new THREE.Mesh(new THREE.CircleGeometry(0.3, 16), new THREE.MeshBasicMaterial({color: 0xffffff})); lightR.position.set(0.8, 1.5, 5.01);
                    const wheelMat = new THREE.MeshStandardMaterial({color: 0x222222});
                    for(let w = -3.5; w <= 3.5; w += 2.5) {
                        const wheelL = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 0.3, 16), wheelMat); wheelL.rotation.z = Math.PI/2; wheelL.position.set(-1.2, 0.4, w);
                        const wheelR = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 0.3, 16), wheelMat); wheelR.rotation.z = Math.PI/2; wheelR.position.set(1.2, 0.4, w);
                        trainGroup.add(wheelL, wheelR);
                    }
                    trainGroup.add(body, stripe, glass, lightL, lightR);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.8, 5, 10), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 2.5;
                    obsGroup.add(trainGroup, hitbox); obsGroup.userData = { isCar: true, speed: 0 }; 
                }
            } else if (selectedMap === 'gurun') {
                if (type === 0) {
                    const cactusMat = new THREE.MeshStandardMaterial({color: 0x2e8b57}); const cactus = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 6, 8), cactusMat); cactus.position.y = 3;
                    const arm1 = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 1.5), cactusMat); arm1.rotation.z = Math.PI/2; arm1.position.set(0.7, 0.5, 0); const arm1Up = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 1.5), cactusMat); arm1Up.position.set(1.3, 1.1, 0);
                    const arm2 = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 1.2), cactusMat); arm2.rotation.z = Math.PI/2; arm2.position.set(-0.6, -0.5, 0); const arm2Up = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 1.2), cactusMat); arm2Up.position.set(-1.1, 0.0, 0);
                    cactus.add(arm1, arm1Up, arm2, arm2Up);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 10, 1.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 5;
                    obsGroup.add(cactus, hitbox);
                } else if (type === 1) {
                    const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(1.6), new THREE.MeshStandardMaterial({color: 0xa0522d, roughness: 0.9})); rock.position.y = 0.8; obsGroup.add(rock);
                } else if (type === 2) {
                    const hole = new THREE.Mesh(new THREE.CylinderGeometry(1.4, 1.4, 0.05, 16), new THREE.MeshBasicMaterial({ color: 0x111111 })); hole.position.y = 0.05; 
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 0.5, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25; obsGroup.add(hole, hitbox);
                } else if (type === 3) {
                    const boneMat = new THREE.MeshStandardMaterial({color: 0xeeeeee, roughness: 1}); const spine = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 3, 8), boneMat); spine.rotation.x = Math.PI/2; spine.position.y = 0.2;
                    const ribGeo = new THREE.TorusGeometry(0.8, 0.15, 8, 16, Math.PI); const rib1 = new THREE.Mesh(ribGeo, boneMat); rib1.position.set(0, 0, 0.5); const rib2 = new THREE.Mesh(ribGeo, boneMat); rib2.position.set(0, 0, 0); const rib3 = new THREE.Mesh(ribGeo, boneMat); rib3.position.set(0, 0, -0.5);
                    obsGroup.add(spine, rib1, rib2, rib3);
                } else if (type === 4) {
                    const quicksand = new THREE.Mesh(new THREE.CylinderGeometry(1.5, 1.5, 0.06, 16), new THREE.MeshStandardMaterial({ color: 0x8b5a2b })); quicksand.position.y = 0.05; 
                    for (let i = 1; i <= 3; i++) { const swirl = new THREE.Mesh(new THREE.TorusGeometry(i * 0.4, 0.05, 4, 16), new THREE.MeshBasicMaterial({color: 0x5c4033})); swirl.rotation.x = Math.PI/2; swirl.position.y = 0.07; obsGroup.add(swirl); }
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.2, 0.5, 2.2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25; obsGroup.add(quicksand, hitbox); obsGroup.userData.isSlow = true;
                } else if (type === 5) {
                    const ramp = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 1.5, 3), new THREE.MeshStandardMaterial({color: 0xEDC9AF})); ramp.rotation.x = -Math.PI / 8; ramp.position.y = -0.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 2, 2.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.5;
                    obsGroup.add(ramp, hitbox); obsGroup.userData.isDune = true; 
                }
            }

            if (obsGroup.userData.forceCenter) { obsGroup.position.set(0, 0, zPos); } else { obsGroup.position.set(xPos, 0, zPos); }
            obsGroup.userData.type = type; obsGroup.userData.active = true; scene.add(obsGroup); obstacles.push(obsGroup);
            if(Math.random() > 0.2) spawnCoinPattern(zPos - 15); 
            if(Math.random() > 0.80) spawnPowerup(LANES[Math.floor(Math.random() * 3)], zPos - 20);
        }

        function spawnCoinPattern(baseZ) {
            const patternType = Math.floor(Math.random() * 4); const startLaneIdx = Math.floor(Math.random() * 3); const zSpacing = 2.5; 
            if (patternType === 0) { const x = LANES[startLaneIdx]; for (let i = 0; i < 5; i++) spawnCoin(x, 1, baseZ - (i * zSpacing)); } 
            else if (patternType === 1) { let currentIdx = startLaneIdx; let dir = currentIdx === 0 ? 1 : (currentIdx === 2 ? -1 : (Math.random() > 0.5 ? 1 : -1)); for (let i = 0; i < 5; i++) { spawnCoin(LANES[currentIdx], 1, baseZ - (i * zSpacing)); currentIdx += dir; if (currentIdx > 2) { currentIdx = 1; dir = -1; } else if (currentIdx < 0) { currentIdx = 1; dir = 1; } } } 
            else if (patternType === 2) { const x = LANES[startLaneIdx]; const heights = [1.0, 2.5, 3.5, 2.5, 1.0]; for (let i = 0; i < 5; i++) spawnCoin(x, heights[i], baseZ - (i * zSpacing * 0.8)); } 
            else if (patternType === 3) { for (let i = 0; i < 3; i++) { for (let j = 0; j < 3; j++) { spawnCoin(LANES[j], 1, baseZ - (i * zSpacing)); } } }
        }

        function spawnCoin(x, y, z) {
            const isDiamond = Math.random() < 0.02; let mesh;
            if (isDiamond) { mesh = new THREE.Mesh(new THREE.OctahedronGeometry(0.6), new THREE.MeshStandardMaterial({ color: 0x00e5ff, metalness: 0.9, roughness: 0.1, transparent: true, opacity: 0.9 })); mesh.userData.isDiamond = true; } 
            else { mesh = new THREE.Mesh(new THREE.CylinderGeometry(0.7, 0.7, 0.15, 16), new THREE.MeshStandardMaterial({ color: 0xFFD700, metalness: 0.8 })); mesh.rotation.x = Math.PI / 2; mesh.userData.isDiamond = false; }
            mesh.position.set(x, y, z); scene.add(mesh); coins.push(mesh); 
        }

        function spawnPowerup(x, z) {
            const rand = Math.random(); let pType = rand < 0.25 ? 'speed' : (rand < 0.50 ? 'magnet' : (rand < 0.60 ? 'shield' : 'mystery'));
            const group = new THREE.Group(); let emoji = '🔮', pColor = 0xffffff;
            if (pType === 'shield') { emoji = '🛡️'; pColor = 0x00ffff; } if (pType === 'speed') { emoji = '⚡'; pColor = 0xffff00; } if (pType === 'magnet') { emoji = '🧲'; pColor = 0xff0000; } if (pType === 'mystery') { emoji = '❓'; pColor = 0x9900ff; } 
            const sprite = createEmojiSprite(emoji); sprite.scale.set(3, 3, 1); sprite.position.y = 2.0; 
            const box = new THREE.Mesh(new THREE.BoxGeometry(1.2, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: pColor, emissive: pColor, emissiveIntensity: 0.5, transparent: true, opacity: 0.5 })); box.position.y = 0.5;
            group.add(sprite, box); group.position.set(x, 0, z); group.userData = { type: pType }; scene.add(group); powerupItems.push(group);
        }

        function togglePause() {
            if (!isPlaying || isCountingDown) return;
            if (!isPaused) { isPaused = true; document.getElementById('pauseMenu').style.display = 'block'; document.getElementById('pauseBtn').innerText = '▶️'; if (audioCtx.state === 'running') audioCtx.suspend(); } 
            else { resumeWithCountdown(); }
        }

        function resumeWithCountdown() {
            isCountingDown = true; document.getElementById('pauseMenu').style.display = 'none'; document.getElementById('pauseBtn').style.display = 'none'; 
            const countdownEl = document.getElementById('countdownOverlay'); countdownEl.style.display = 'flex';
            let count = 3; countdownEl.innerText = count; playSound('select');
            const interval = setInterval(() => { count--; if (count > 0) { countdownEl.innerText = count; playSound('select'); } else { clearInterval(interval); countdownEl.style.display = 'none'; document.getElementById('pauseBtn').style.display = 'flex'; document.getElementById('pauseBtn').innerText = '⏸️'; isCountingDown = false; isPaused = false; if (audioCtx.state === 'suspended') audioCtx.resume(); } }, 1000);
        }

        function restartFromPause() {
            isPaused = false; document.getElementById('pauseMenu').style.display = 'none'; document.getElementById('pauseBtn').innerText = '⏸️'; if (audioCtx.state === 'suspended') audioCtx.resume(); 
            savedData.missionsList.forEach(m => { if (!m.claimed) { if (m.type === 'distance') m.progress += Math.floor(currentRunData.distance); if (m.type === 'coin') m.progress += currentRunData.coins; if (m.type === 'jump') m.progress += currentRunData.jumps; if (m.progress > m.target) m.progress = m.target; } });
            saveGame(); resetGame(); 
        }

        function quitFromPause() {
            isPaused = false; document.getElementById('pauseMenu').style.display = 'none'; document.getElementById('pauseBtn').innerText = '⏸️'; if (audioCtx.state === 'suspended') audioCtx.resume(); 
            savedData.missionsList.forEach(m => { if (!m.claimed) { if (m.type === 'distance') m.progress += Math.floor(currentRunData.distance); if (m.type === 'coin') m.progress += currentRunData.coins; if (m.type === 'jump') m.progress += currentRunData.jumps; if (m.progress > m.target) m.progress = m.target; } });
            saveGame(); backToMenu(); 
        }

        function setupControls() {
            if (controlsSetup) return; controlsSetup = true;
            window.addEventListener('keydown', (e) => {
                if(!isPlaying) return; const key = e.key.toLowerCase();
                if (key === 'escape' || key === 'p') { togglePause(); return; }
                if (isPaused) return;
                if(key === 'arrowleft' || key === 'a') movePlayer(-1); if(key === 'arrowright' || key === 'd') movePlayer(1);
                if(key === 'arrowup' || key === 'w' || key === ' ') jump(); if(key === 'arrowdown' || key === 's') slide();
            });
            let touchStartX = 0, touchStartY = 0;
            document.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; touchStartY = e.changedTouches[0].screenY; });
            document.addEventListener('touchend', e => {
                if(!isPlaying || isPaused) return; const diffX = e.changedTouches[0].screenX - touchStartX, diffY = e.changedTouches[0].screenY - touchStartY;
                if (Math.abs(diffX) > 40 || Math.abs(diffY) > 40) { if (Math.abs(diffX) > Math.abs(diffY)) { if (diffX > 0) movePlayer(1); else movePlayer(-1); } else { if (diffY > 0) slide(); else jump(); } }
            });
        }

        function movePlayer(dir) {
            if (tutorialStep === 1 && dir === -1) { tutorialStep = 2; showTutorialStep(); } else if (tutorialStep === 2 && dir === 1) { tutorialStep = 3; showTutorialStep(); }
            currentLane += dir; if(currentLane < 0) currentLane = 0; if(currentLane > 2) currentLane = 2;
        }

        function jump() {
            if (tutorialStep === 3) { tutorialStep = 4; showTutorialStep(); }
            if(!isJumping && !isSliding) {
                isJumping = true; let jumpPower = 0.35; 
                if (selectedChar === 'ksatria' || selectedChar === 'penyihir') jumpPower = 0.40; if (selectedChar === 'api' || selectedChar === 'pahlawan') jumpPower = 0.45; 
                velocityY = jumpPower; playSound('jump'); currentRunData.jumps++;
            }
        }

        function slide() {
            if (tutorialStep === 4) { tutorialStep = 0; showTutorialStep(); }
            if(!isJumping && !isSliding) { isSliding = true; slideTimer = 40; player.children[0].scale.y = 0.5; player.children[0].position.y = 0.5; if(playerModel) { playerModel.position.y = -0.8; playerModel.rotation.x = -Math.PI / 3; } }
        }

        function startGame() {
            document.getElementById('mainMenu').style.display = 'none'; document.getElementById('gameOverMenu').style.display = 'none'; document.getElementById('hud').style.display = 'flex';
            if (menuPreviewReq) cancelAnimationFrame(menuPreviewReq); stopMenuBgm();
            gravity = (selectedMap === 'fantasi') ? -0.009 : -0.015; buildWorld();
            score = 0; coinCount = 0; currentRunData = { coins: 0, diamonds: 0, distance: 0, jumps: 0, startMap: selectedMap };
            document.getElementById('coinDisplay').innerText = `🪙 0`; document.getElementById('diamondDisplay').innerText = `💎 0`;
            gameSpeed = selectedMap === 'lava' ? 0.48 : 0.4; baseGameSpeed = selectedMap === 'lava' ? 0.48 : 0.4; currentLane = 1; isJumping = false; isSliding = false; isPlaying = true; isPaused = false;
            activePowerup = null; hasShield = false; shieldAura.visible = false; shieldTimer = 0; bushHitCount = 0; enemyZOffset = 15; speedMultiplier = 1.0; morningTransition = 0; sandstormTransition = 0; rainTransition = (selectedMap === 'sungai') ? 1 : 0; reviveDiamondCost = 5; graceTimer = 0; blurTimer = 0; creepingTimer = 0; forestRainTarget = 0; forestNextWeatherChange = 1400; 
            if (enemyModel) enemyModel.position.set(LANES[currentLane], 0, 15);
            document.getElementById('pauseMenu').style.display = 'none'; document.getElementById('pauseBtn').innerText = '⏸️'; document.getElementById('powerupDisplay').style.display = 'none'; document.getElementById('warningDisplay').style.display = 'none'; document.getElementById('blurOverlay').style.display = 'none';
            if (!savedData.hasSeenTutorial) { tutorialStep = 1; gameSpeed = 0.15; baseGameSpeed = 0.15; showTutorialStep(); } else { tutorialStep = 0; }
            startAmbient(selectedMap);
        }

        function showTutorialStep() {
            const tutUI = document.getElementById('stepTutorial'), icon = document.getElementById('tutStepIcon'), text = document.getElementById('tutStepText');
            if (tutorialStep > 0) { tutUI.style.display = 'flex'; tutUI.style.flexDirection = 'column'; }
            if (tutorialStep === 1) { icon.innerText = '👈'; text.innerHTML = 'Geser KIRI<br>untuk pindah jalur'; } else if (tutorialStep === 2) { icon.innerText = '👉'; text.innerHTML = 'Bagus! Geser KANAN<br>untuk kembali'; } else if (tutorialStep === 3) { icon.innerText = '👆'; text.innerHTML = 'Geser ATAS<br>untuk Melompat'; } else if (tutorialStep === 4) { icon.innerText = '👇'; text.innerHTML = 'Geser BAWAH<br>untuk Meluncur'; } else { tutUI.style.display = 'none'; savedData.hasSeenTutorial = true; saveGame(); baseGameSpeed = 0.4; gameSpeed = 0.4; }
        }

        function resetGame() { startGame(); }

        function backToMenu() {
            document.getElementById('gameOverMenu').style.display = 'none'; document.getElementById('hud').style.display = 'none'; document.getElementById('mainMenu').style.display = 'block';
            isPlaying = false; stopAmbient(); playMenuBgm(); animateMenuPreview(); setupMenuUI();
        }

        function gameOver() {
            isPlaying = false; stopAmbient(); playSound('crash'); blurTimer = 0; document.getElementById('blurOverlay').style.display = 'none';
            
            savedData.missionsList.forEach(m => {
                if (!m.claimed) {
                    if (m.type === 'distance') m.progress += Math.floor(currentRunData.distance);
                    if (m.type === 'coin') m.progress += currentRunData.coins;
                    if (m.type === 'jump') m.progress += currentRunData.jumps;
                    if (m.progress > m.target) m.progress = m.target;
                }
            });
            saveGame(); updateMenuCoinsDisplay();
            
            if(playerModel) { playerModel.rotation.z = Math.PI / 2; playerModel.position.y = 0.5; }
            const btnContDiamond = document.getElementById('btnContinueDiamond'); if (btnContDiamond) btnContDiamond.innerText = `Bangkit (${reviveDiamondCost} 💎)`;
            setTimeout(() => { document.getElementById('gameOverMenu').style.display = 'block'; document.getElementById('finalScore').innerText = `Jarak: ${Math.floor(score)}m`; document.getElementById('finalCoins').innerText = `Pendapatan: ${currentRunData.coins} 🪙 | ${currentRunData.diamonds} 💎`; }, 1000);
        }

        function continueGame() {
            let canRevive = false;
            if (savedData.totalDiamonds >= reviveDiamondCost) { savedData.totalDiamonds -= reviveDiamondCost; reviveDiamondCost += 5; canRevive = true; } else { showModal("Diamond (💎) tidak cukup!", false); }
            if (canRevive) {
                saveGame(); updateMenuCoinsDisplay(); document.getElementById('gameOverMenu').style.display = 'none';
                if(playerModel) { playerModel.rotation.z = 0; playerModel.position.y = 0; }
                for(let i = obstacles.length - 1; i >= 0; i--) { let obs = obstacles[i]; if (obs.position.z > player.position.z - 60 && obs.position.z < player.position.z + 20) { scene.remove(obs); obstacles.splice(i, 1); } }
                for(let i = coins.length - 1; i >= 0; i--) { let coin = coins[i]; if (coin.position.z > player.position.z - 40 && coin.position.z < player.position.z + 10) { scene.remove(coin); coins.splice(i, 1); } }
                bushHitCount = 0; enemyZOffset = 15; if (enemyModel) enemyModel.position.set(LANES[currentLane], 0, 15);
                isJumping = false; isSliding = false; activePowerup = null; powerupTimer = 0; blurTimer = 0; creepingTimer = 0; isPaused = false; document.getElementById('pauseMenu').style.display = 'none'; document.getElementById('pauseBtn').innerText = '⏸️'; document.getElementById('powerupDisplay').style.display = 'none'; document.getElementById('blurOverlay').style.display = 'none';
                graceTimer = 120; speedMultiplier = 0.1; isPlaying = true; startAmbient(selectedMap); 
            }
        }

        function changeMapDuringRun(newMapId) {
            selectedMap = newMapId;
            const mapTheme = mapsData.find(m => m.id === newMapId);
            
            scene.background.setHex(mapTheme.bg);
            scene.fog.color.setHex(mapTheme.fog);

            ground.material.map = generateGroundTexture(newMapId);
            ground.material.color.setHex(0xffffff);
            ground.material.needsUpdate = true;

            let farColor = mapTheme.ground;
            if (newMapId === 'desa') farColor = 0x3cb371; 
            if (newMapId === 'hutan') farColor = 0x1e3315; 
            if (farGround) farGround.material.color.setHex(farColor);

            laneLines.forEach(line => {
                line.material.color.setHex(0x2a1608);
                line.material.opacity = 0.2;
            });

            backgroundDecor.forEach(bd => scene.remove(bd));
            backgroundDecor = [];
            
            if (newMapId === 'desa') {
                for(let i = 0; i < 30; i++) { 
                    const treeGroup = createVariedTree(1.5 + Math.random(), false); 
                    const side = Math.random() > 0.5 ? 1 : -1; 
                    treeGroup.position.set(side * (30 + Math.random()*40), 0, -60 - Math.random()*120); 
                    scene.add(treeGroup); backgroundDecor.push(treeGroup); 
                }
            } else if (newMapId === 'hutan') {
                for(let i = 0; i < 16; i++) { 
                    const mountColors = [0x142b14, 0x1e3b1e, 0x173017];
                    const mountain = new THREE.Mesh(new THREE.ConeGeometry(30 + Math.random()*20, 50 + Math.random()*40, 8), new THREE.MeshStandardMaterial({color: mountColors[Math.floor(Math.random() * mountColors.length)], roughness: 1}));
                    const side = Math.random() > 0.5 ? 1 : -1; mountain.position.set(side * (50 + Math.random()*30), -5, -60 - Math.random()*80);
                    if (Math.random() > 0.3) { const giantTree = createVariedTree(3 + Math.random()*2, true); giantTree.position.set(side * (25 + Math.random()*15), -2, -40 - Math.random()*40); scene.add(giantTree); backgroundDecor.push(giantTree); }
                    scene.add(mountain); backgroundDecor.push(mountain);
                }
            }

            startAmbient(newMapId);

            const warningEl = document.getElementById('warningDisplay');
            warningEl.innerText = `MEMASUKI KAWASAN ${mapTheme.name.toUpperCase()}!`;
            warningEl.style.color = '#00e5ff';
            warningEl.style.display = 'block';
            setTimeout(() => {
                warningEl.style.display = 'none';
                warningEl.style.color = 'white'; 
            }, 3000);
        }

        function animate() {
            requestAnimationFrame(animate);
            if (isPlaying && !isPaused) {
                if (currentRunData.startMap === 'hutan') {
                    const cycle = Math.floor(score) % 2200;
                    if (cycle >= 2000 && selectedMap !== 'desa') {
                        changeMapDuringRun('desa');
                    } else if (cycle < 2000 && score > 10 && selectedMap !== 'hutan') {
                        changeMapDuringRun('hutan');
                    }
                }

                if (selectedMap === 'kota' && score >= 3000 && morningTransition < 1) {
                    morningTransition += 0.002; if (morningTransition > 1) morningTransition = 1;
                    const currentColor = new THREE.Color(0x111122).lerp(new THREE.Color(0x87CEEB), morningTransition);
                    scene.background.set(currentColor); scene.fog.color.set(currentColor);
                    ambientLight.intensity = 0.5 + (0.4 * morningTransition); dirLight.intensity = 0.8 + (0.4 * morningTransition);
                    if (farGround) farGround.material.color.set(new THREE.Color(0x111122).lerp(new THREE.Color(0xaaaaaa), morningTransition));
                }

                if (selectedMap === 'gurun') {
                    let targetSandstorm = 0; if (score >= 1699 && score < 2475) targetSandstorm = 1; else if (score >= 2475) targetSandstorm = 0; 
                    if (sandstormTransition < targetSandstorm) { sandstormTransition += 0.002; if (sandstormTransition > targetSandstorm) sandstormTransition = targetSandstorm; } else if (sandstormTransition > targetSandstorm) { sandstormTransition -= 0.002; if (sandstormTransition < targetSandstorm) sandstormTransition = targetSandstorm; }
                    if (sandSystem) sandSystem.material.opacity = 0.7 * (1 - sandstormTransition); 
                    if (scene.fog) scene.fog.density = 0.025 * (1 - (sandstormTransition * 0.5)); 
                }

                if (['desa', 'sungai', 'hutan'].includes(selectedMap)) {
                    let targetRain = (selectedMap === 'sungai') ? 1 : 0;
                    if (selectedMap === 'desa') { targetRain = (score >= 1200 && score < 2000) ? 1 : 0; } 
                    else if (selectedMap === 'sungai') { targetRain = (score >= 1899 && score < 2256) ? 0 : 1; } 
                    else if (selectedMap === 'hutan') { if (score < 934) { targetRain = 0; } else if (score >= 934 && score < 1400) { targetRain = 1; } else { if (score >= forestNextWeatherChange) { forestRainTarget = forestRainTarget === 0 ? 1 : 0; forestNextWeatherChange = score + 400 + Math.random() * 400; } targetRain = forestRainTarget; } }

                    if (rainTransition < targetRain) { rainTransition += 0.002; if (rainTransition > targetRain) rainTransition = targetRain; } else if (rainTransition > targetRain) { rainTransition -= 0.002; if (rainTransition < targetRain) rainTransition = targetRain; }
                    if (rainSystem) rainSystem.material.opacity = 0.7 * rainTransition;
                    if (currentRainGain) currentRainGain.gain.setTargetAtTime(0.3 * rainTransition, audioCtx.currentTime, 0.1);
                    if (['desa', 'hutan'].includes(selectedMap)) { ambientLight.intensity = 0.6 - (0.3 * rainTransition); const baseCol = new THREE.Color(); if (selectedMap === 'desa') baseCol.setHex(0x87CEFA); if (selectedMap === 'hutan') baseCol.setHex(0x87CEEB); const curCol = baseCol.lerp(new THREE.Color(0x556677), rainTransition); scene.background.set(curCol); scene.fog.color.set(curCol); } 
                    else if (selectedMap === 'sungai') { ambientLight.intensity = 0.4 + (0.2 * (1 - rainTransition)); const curCol = new THREE.Color(0x87CEEB).lerp(new THREE.Color(0x6e7f80), rainTransition); scene.background.set(curCol); scene.fog.color.set(curCol); }
                }

                if (creepingTimer > 0) { creepingTimer--; speedMultiplier = 0.2; } else if (graceTimer > 0) { graceTimer--; speedMultiplier = 0.1; } else if (speedMultiplier < 1.0) { speedMultiplier += 0.005; if (speedMultiplier > 1.0) speedMultiplier = 1.0; }

                if (activePowerup === 'speed') { gameSpeed = baseGameSpeed * 1.8; } else { gameSpeed = baseGameSpeed * speedMultiplier; if (speedMultiplier === 1.0) baseGameSpeed += 0.00008; }
                if (selectedChar === 'pahlawan') { gameSpeed += 0.06; score += gameSpeed * 0.3; }
                score += gameSpeed * 0.5; currentRunData.distance = score; 
                document.getElementById('scoreDisplay').innerText = `Jarak: ${Math.floor(score)}m`;

                if (ground && ground.material.map) ground.material.map.offset.y -= gameSpeed * 0.05; 
                sidewalks.forEach(s => { if (s.material.map) s.material.map.offset.y -= gameSpeed * 0.05; });

                if (rainSystem && rainSystem.material.opacity > 0) { const positions = rainSystem.geometry.attributes.position.array; for (let i = 1; i < positions.length; i += 3) { positions[i] -= 0.5; if (positions[i] < 0) positions[i] = 40; } rainSystem.geometry.attributes.position.needsUpdate = true; }
                if (sandSystem && sandSystem.material.opacity > 0) { const positions = sandSystem.geometry.attributes.position.array; const currentWindSpeed = 0.6 * (1 - sandstormTransition); for (let i = 0; i < positions.length; i += 3) { positions[i] -= currentWindSpeed; positions[i+2] += gameSpeed; if (positions[i] < -40) positions[i] = 40; if (positions[i+2] > 20) positions[i+2] = -60; } sandSystem.geometry.attributes.position.needsUpdate = true; }
                if (fantasyParticles && fantasyParticles.material.opacity > 0) { const positions = fantasyParticles.geometry.attributes.position.array; for (let i = 1; i < positions.length; i += 3) { positions[i] += 0.05; if (positions[i] > 40) positions[i] = -20; positions[i-1] += Math.sin(Date.now()*0.001 + positions[i])*0.02; } fantasyParticles.geometry.attributes.position.needsUpdate = true; }
                if (riverMesh) riverMesh.position.y = -0.05 + Math.sin(Date.now() * 0.003) * 0.04; 

                for (let i = backgroundDecor.length - 1; i >= 0; i--) { let bg = backgroundDecor[i]; bg.position.z += gameSpeed * 0.2; if (bg.position.z > 20) bg.position.z = -150 - Math.random() * 50; }

                spawnTimer++;
                if(spawnTimer > 100 / (gameSpeed * 2)) { spawnObstacle(); spawnScenery(-100); spawnTimer = 0; }

                const targetX = LANES[currentLane]; player.position.x += (targetX - player.position.x) * 0.15;
                if (playerLight) playerLight.position.set(player.position.x, player.position.y + 2, player.position.z + 1);

                if (enemyModel) {
                    if (enemyZOffset < 15 && bushHitCount < 3) { enemyZOffset += 0.02; if (enemyZOffset > 14) bushHitCount = 0; }
                    const targetEnemyZ = player.position.z + enemyZOffset; const catchSpeed = bushHitCount >= 3 ? 0.15 : 0.1; 
                    enemyModel.position.z += (targetEnemyZ - enemyModel.position.z) * catchSpeed; enemyModel.position.x += (player.position.x - enemyModel.position.x) * 0.1;
                    const runAnim = Date.now() * 0.02; enemyModel.position.y = Math.abs(Math.sin(runAnim * 2)) * 0.2;
                    enemyModel.userData.armL.rotation.x = Math.sin(runAnim) * 1.2; enemyModel.userData.armR.rotation.x = Math.sin(runAnim + Math.PI) * 1.2; enemyModel.userData.legL.rotation.x = Math.sin(runAnim + Math.PI) * 1.2; enemyModel.userData.legR.rotation.x = Math.sin(runAnim) * 1.2;
                }

                if(isJumping) {
                    player.position.y += velocityY; velocityY += gravity;
                    if(player.position.y <= 0) { player.position.y = 0; isJumping = false; }
                    if(playerModel) {
                        playerModel.rotation.x = 0; playerModel.rotation.z = 0; playerModel.userData.armL.rotation.z = 0; playerModel.userData.armR.rotation.z = 0;
                        if (selectedChar === 'penyihir') { playerModel.userData.armL.rotation.x = -Math.PI / 1.5; playerModel.userData.armR.rotation.x = -Math.PI / 1.5; playerModel.userData.legL.rotation.x = Math.PI / 8; playerModel.userData.legR.rotation.x = Math.PI / 8; } 
                        else { playerModel.userData.armL.rotation.x = -Math.PI / 4; playerModel.userData.armR.rotation.x = Math.PI / 4; playerModel.userData.legL.rotation.x = Math.PI / 6; playerModel.userData.legR.rotation.x = -Math.PI / 6; }
                    }
                } else if (isSliding) {
                    slideTimer--;
                    if(slideTimer <= 0) { isSliding = false; player.children[0].scale.y = 1; player.children[0].position.y = 1; if(playerModel) { playerModel.position.y = 0; playerModel.rotation.x = 0; playerModel.rotation.z = 0; playerModel.userData.armL.rotation.z = 0; playerModel.userData.armR.rotation.z = 0; } }
                    if(playerModel) { playerModel.userData.armL.rotation.x = Math.PI / 2.5; playerModel.userData.armR.rotation.x = Math.PI / 2.5; }
                } else if (creepingTimer > 0) {
                    if(playerModel) {
                        const creepAnim = Date.now() * 0.008; playerModel.position.y = -0.5; playerModel.rotation.x = Math.PI / 2.5; playerModel.rotation.z = Math.sin(creepAnim * 2) * 0.05; 
                        playerModel.userData.armL.rotation.z = 0; playerModel.userData.armR.rotation.z = 0;
                        playerModel.userData.armL.rotation.x = Math.sin(creepAnim) * 0.5; playerModel.userData.armR.rotation.x = Math.sin(creepAnim + Math.PI) * 0.5; playerModel.userData.legL.rotation.x = Math.sin(creepAnim + Math.PI) * 0.5; playerModel.userData.legR.rotation.x = Math.sin(creepAnim) * 0.5;
                    }
                } else {
                    if(playerModel) {
                        playerModel.rotation.z = 0;
                        if (selectedChar === 'penyihir') {
                            const floatAnim = Date.now() * 0.004; playerModel.position.y = 0.4 + Math.sin(floatAnim) * 0.2; playerModel.rotation.x = 0.15; 
                            playerModel.userData.armL.rotation.x = -Math.PI / 6 + Math.sin(floatAnim) * 0.1; playerModel.userData.armR.rotation.x = -Math.PI / 6 + Math.sin(floatAnim) * 0.1; playerModel.userData.armL.rotation.z = Math.PI / 8; playerModel.userData.armR.rotation.z = -Math.PI / 8;
                            playerModel.userData.legL.rotation.x = Math.PI / 12; playerModel.userData.legR.rotation.x = Math.PI / 10;
                        } else {
                            const runAnim = Date.now() * 0.015; playerModel.position.y = Math.abs(Math.sin(runAnim * 2)) * 0.2; playerModel.rotation.x = 0; playerModel.userData.armL.rotation.z = 0; playerModel.userData.armR.rotation.z = 0;
                            playerModel.userData.armL.rotation.x = Math.sin(runAnim) * 0.8; playerModel.userData.armR.rotation.x = Math.sin(runAnim + Math.PI) * 0.8; playerModel.userData.legL.rotation.x = Math.sin(runAnim + Math.PI) * 0.8; playerModel.userData.legR.rotation.x = Math.sin(runAnim) * 0.8;
                        }
                    }
                }
                
                if (activePowerup) { powerupTimer--; if (powerupTimer <= 0) { activePowerup = null; document.getElementById('powerupDisplay').style.display = 'none'; gameSpeed = baseGameSpeed; } }

                const charObj = charactersData.find(c => c.id === selectedChar);
                if (charObj && charObj.effect && !isSliding) {
                    const spawnChance = charObj.effect === 'neon_purple' ? 0.6 : 0.3; 
                    if (Math.random() < spawnChance && playerParticles) { 
                        let pCol = 0xff0000, pGeo = new THREE.BoxGeometry(0.2, 0.2, 0.2), posY = player.position.y + Math.random()*1.5, posX = player.position.x + (Math.random()-0.5)*0.6, posZ = player.position.z + (Math.random()-0.5)*0.6;
                        if (charObj.effect === 'neon_blue') { pCol = 0x00ffff; pGeo = new THREE.SphereGeometry(0.15); }
                        if (charObj.effect === 'fire_green') pCol = 0x39ff14;
                        if (charObj.effect === 'fire_red') { 
                            let activeCostume = savedData.selectedCostumes['api'] || 'default'; pCol = (selectedChar === 'api' && activeCostume === 'biru') ? (Math.random() > 0.5 ? 0x00e5ff : 0x0055ff) : (Math.random() > 0.5 ? 0xff3300 : 0xffff00); 
                            pGeo = new THREE.DodecahedronGeometry(0.12 + Math.random()*0.1); 
                            if (selectedChar === 'api') { posY = player.position.y + Math.random() * 0.4; posX = player.position.x + (Math.random()-0.5)*0.8; posZ = player.position.z + (Math.random()-0.5)*0.8; } else { posY = player.position.y + Math.random() * 2.0; }
                        }
                        if (charObj.effect === 'neon_purple') { 
                            pCol = Math.random() > 0.5 ? 0xaa00ff : 0x00e5ff; pGeo = new THREE.OctahedronGeometry(0.08 + Math.random()*0.1); 
                            if (Math.random() > 0.5) posY = player.position.y + 0.1; else { posY = player.position.y + 1.0 + Math.random()*1.5; posX = player.position.x + (Math.random()-0.5)*1.5; }
                        }
                        let pMesh = new THREE.Mesh(pGeo, new THREE.MeshBasicMaterial({color: pCol, transparent: true, opacity: 0.8})); pMesh.position.set(posX, posY, posZ); playerParticles.add(pMesh);
                    }
                }

                if (playerParticles) {
                    for(let i = playerParticles.children.length - 1; i >= 0; i--) {
                        let p = playerParticles.children[i];
                        if (selectedChar === 'penyihir') { p.position.y += 0.02; p.scale.multiplyScalar(0.96); p.material.opacity -= 0.02; } 
                        else if (selectedChar === 'api') { p.position.y += 0.08; p.scale.multiplyScalar(0.85); p.material.opacity -= 0.05; } 
                        else { p.position.y += 0.05; p.scale.multiplyScalar(0.92); p.material.opacity -= 0.04; }
                        p.rotation.x += 0.1; p.rotation.y += 0.1;
                        if (p.material.opacity <= 0) playerParticles.remove(p);
                    }
                }

                if (blurTimer > 0) { blurTimer--; if (blurTimer <= 0) document.getElementById('blurOverlay').style.display = 'none'; }
                if (hasShield) { shieldTimer--; shieldAura.material.opacity = (shieldTimer < 60 && Math.floor(Date.now() / 100) % 2 !== 0) ? 0.1 : 0.6; if (shieldTimer <= 0) { hasShield = false; shieldAura.visible = false; } }
                
                let magnetRange = 0; if (activePowerup === 'magnet') magnetRange = 25; 
                if (['penyihir', 'pahlawan'].includes(selectedChar)) magnetRange = (activePowerup === 'magnet') ? 40 : 8; 
                if (magnetRange > 0) { let targetPos = new THREE.Vector3(player.position.x, player.position.y + 1, player.position.z); coins.forEach(c => { if (c.position.z > player.position.z - magnetRange && c.position.z < player.position.z + 10) { c.position.lerp(targetPos, 0.12); c.userData.isMagnetized = true; } }); }

                const pBox = new THREE.Box3().setFromObject(player.children[0]); pBox.expandByScalar(-0.2); 

                for(let i = obstacles.length - 1; i >= 0; i--) {
                    let obs = obstacles[i];
                    if (obs.userData.isCar && obs.userData.speed) obs.position.z += gameSpeed + obs.userData.speed; else obs.position.z += gameSpeed;
                    if (obs.userData.isDragon) { obs.children[0].children[1].rotation.z = Math.sin(Date.now() * 0.02) * 0.5; obs.children[0].children[2].rotation.z = -Math.sin(Date.now() * 0.02) * 0.5; obs.position.y = Math.sin(Date.now() * 0.005) * 0.5; }
                    if (obs.userData.isGhost) { obs.position.x += Math.sin(Date.now() * 0.003 + obs.position.z) * 0.05; obs.children[0].rotation.y += 0.02; obs.children[0].rotation.x += 0.01; }
                    if (obs.userData.isTeleport) { obs.children[0].rotation.z -= 0.05; }
                    if (obs.userData.isCreepingRoot) { obs.position.x += obs.userData.speedX * obs.userData.moveDir; if (obs.position.x > LANE_WIDTH + 0.5) obs.userData.moveDir = -1; else if (obs.position.x < -LANE_WIDTH - 0.5) obs.userData.moveDir = 1; obs.children[0].rotation.y += 0.05; obs.children[0].rotation.z = Math.sin(Date.now() * 0.005) * 0.2; }
                    if (obs.userData.isWalkingPerson) { const runAnim = Date.now() * 0.005; obs.userData.legL.rotation.x = Math.sin(runAnim) * 0.6; obs.userData.legR.rotation.x = Math.sin(runAnim + Math.PI) * 0.6; if (obs.userData.armL) { obs.userData.armL.rotation.x = Math.sin(runAnim + Math.PI) * 0.6; obs.userData.armR.rotation.x = Math.sin(runAnim) * 0.6; } }

                    if(obs.userData.active) {
                        let checkMeshes = []; obs.children.forEach(child => { if (child.type === "Mesh" || child.type === "Group") checkMeshes.push(child); });
                        let isHit = false;
                        if (checkMeshes.length > 0) { const oBox = new THREE.Box3().setFromObject(obs); if (obs.userData.type === 0 && isSliding && ['kota','rel','hutan','desa','sungai','fantasi'].includes(selectedMap)) isHit = false; else isHit = pBox.intersectsBox(oBox); }

                        if(isHit) {
                            if (obs.userData.isTeleport) {
                                let newLane = currentLane; while(newLane === currentLane) newLane = Math.floor(Math.random() * 3);
                                currentLane = newLane; player.position.x = LANES[currentLane]; playSound('select');
                                scene.background.setHex(0xffffff); setTimeout(() => scene.background.setHex(mapsData.find(m => m.id === selectedMap).bg), 100);
                                obs.userData.active = false; scene.remove(obs);
                            } else if (obs.userData.isDune) {
                                if (!isJumping) { isJumping = true; velocityY = 0.5; playSound('jump'); obs.userData.active = false; }
                            } else if (obs.userData.isInstaDeath) {
                                gameOver(); obs.userData.active = false;
                            } else if (obs.userData.isSlow || obs.userData.isCreepingRoot) { 
                                if (hasShield) { hasShield = false; shieldAura.visible = false; playSound('jump'); obs.userData.active = false; scene.remove(obs); } 
                                else {
                                    bushHitCount++; if (bushHitCount === 1) enemyZOffset = 7; else if (bushHitCount === 2) enemyZOffset = 3; else if (bushHitCount >= 3) enemyZOffset = -0.5; 
                                    speedMultiplier = 0.4; playSound('crash');
                                    const warningEl = document.getElementById('warningDisplay'); if (obs.userData.isCreepingRoot) { creepingTimer = 100; warningEl.innerText = 'TERJERAT AKAR!'; } else { warningEl.innerText = '⚠️ MUSUH MENDEKAT!'; }
                                    warningEl.style.display = 'block'; setTimeout(() => warningEl.style.display = 'none', 1500);
                                    if (bushHitCount >= 3) setTimeout(() => { if(isPlaying) gameOver(); }, 1200);
                                    obs.userData.active = false;
                                }
                            } else {
                                if (hasShield) { hasShield = false; shieldAura.visible = false; obs.userData.active = false; scene.remove(obs); playSound('jump'); } else { gameOver(); obs.userData.active = false; }
                            }
                        }
                    }
                    if(obs.position.z > 10) { scene.remove(obs); obstacles.splice(i, 1); }
                }

                for(let i = coins.length - 1; i >= 0; i--) {
                    let coin = coins[i]; coin.position.z += gameSpeed;
                    if (coin.userData.isDiamond) { coin.rotation.y += 0.05; coin.rotation.x += 0.05; } else { coin.rotation.z += 0.1; }
                    const playerCenterY = player.position.y + 1;
                    const hitRadiusX = coin.userData.isMagnetized ? 3.5 : 1.5, hitRadiusY = coin.userData.isMagnetized ? 3.5 : 2.0, hitRadiusZ = coin.userData.isMagnetized ? 3.5 : 1.5;
                    if(Math.abs(coin.position.z - player.position.z) < hitRadiusZ && Math.abs(coin.position.x - player.position.x) < hitRadiusX && Math.abs(coin.position.y - playerCenterY) < hitRadiusY) { 
                        if (coin.userData.isDiamond) { currentRunData.diamonds++; savedData.totalDiamonds++; document.getElementById('diamondDisplay').innerText = `💎 ${currentRunData.diamonds}`; updateMenuCoinsDisplay(); playSound('diamond'); } 
                        else { coinCount++; currentRunData.coins++; savedData.totalCoins++; document.getElementById('coinDisplay').innerText = `🪙 ${coinCount}`; updateMenuCoinsDisplay(); playSound('coin'); }
                        scene.remove(coin); coins.splice(i, 1); continue;
                    }
                    if(coin.position.z > 10) { scene.remove(coin); coins.splice(i, 1); }
                }
                
                for(let i = powerupItems.length - 1; i >= 0; i--) {
                    let p = powerupItems[i]; p.position.z += gameSpeed; p.children[1].rotation.y += 0.1; p.children[1].rotation.x += 0.05; p.position.y = 0.5 + Math.sin(Date.now() * 0.005) * 0.3; 
                    if(Math.abs(p.position.z - player.position.z) < 2.5 && Math.abs(p.position.x - player.position.x) < 2.5 && player.position.y < 3) {
                        const type = p.userData.type; let displayMsg = '';
                        if (type === 'mystery') {
                            const effects = ['shield', 'speed', 'magnet', 'bonus_coin', 'zonk_slow', 'zonk_blur']; const randomEffect = effects[Math.floor(Math.random() * effects.length)];
                            if (randomEffect === 'zonk_slow') {
                                playSound('crash'); speedMultiplier = 0.3; bushHitCount++; if (bushHitCount === 1) enemyZOffset = 7; else if (bushHitCount === 2) enemyZOffset = 3; else if (bushHitCount >= 3) enemyZOffset = -0.5; 
                                document.getElementById('warningDisplay').style.display = 'block'; setTimeout(() => document.getElementById('warningDisplay').style.display = 'none', 1500);
                                if (bushHitCount >= 3) setTimeout(() => { if(isPlaying) gameOver(); }, 1200);
                                displayMsg = '❓ MISTERI: 🐌 ZONK (MELAMBAT)!';
                            } else if (randomEffect === 'zonk_blur') {
                                playSound('crash'); blurTimer = 180; document.getElementById('blurOverlay').style.display = 'block'; displayMsg = '❓ MISTERI: 😵 ZONK (MATA KABUR)!';
                            } else {
                                playSound('coin'); 
                                if (randomEffect === 'shield') { hasShield = true; shieldAura.visible = true; shieldAura.material.opacity = 0.6; shieldTimer = 400; displayMsg = '❓ MISTERI: 🛡️ PELINDUNG'; } 
                                else if (randomEffect === 'speed') { activePowerup = 'speed'; powerupTimer = 300; gameSpeed = baseGameSpeed * 1.8; displayMsg = '❓ MISTERI: ⚡ KECEPATAN'; } 
                                else if (randomEffect === 'magnet') { activePowerup = 'magnet'; powerupTimer = 400; displayMsg = '❓ MISTERI: 🧲 MAGNET'; } 
                                else if (randomEffect === 'bonus_coin') { coinCount += 50; savedData.totalCoins += 50; currentRunData.coins += 50; document.getElementById('coinDisplay').innerText = `🪙 ${coinCount}`; updateMenuCoinsDisplay(); displayMsg = '❓ MISTERI: 💰 +50 KOIN!'; }
                            }
                        } else {
                            playSound('coin');
                            if (type === 'shield') { hasShield = true; shieldAura.visible = true; shieldAura.material.opacity = 0.6; shieldTimer = 400; displayMsg = '🛡️ PELINDUNG'; } 
                            else if (type === 'speed') { activePowerup = 'speed'; powerupTimer = 300; gameSpeed = baseGameSpeed * 1.8; displayMsg = '⚡ SPEED BOOST'; } 
                            else if (type === 'magnet') { activePowerup = 'magnet'; powerupTimer = 400; displayMsg = '🧲 MAGNET'; }
                        }
                        document.getElementById('powerupDisplay').innerText = displayMsg; document.getElementById('powerupDisplay').style.display = 'block';
                        if (activePowerup !== 'speed' && activePowerup !== 'magnet') { activePowerup = 'text_only'; powerupTimer = 120; }
                        scene.remove(p); powerupItems.splice(i, 1); continue;
                    }
                    if(p.position.z > 10) { scene.remove(p); powerupItems.splice(i, 1); }
                }
                for(let i = scenery.length - 1; i >= 0; i--) { let s = scenery[i]; s.position.z += gameSpeed; if(s.position.z > 20) { scene.remove(s); scenery.splice(i, 1); } }
            }
            if(renderer && scene && camera) renderer.render(scene, camera);
        }

        function showSplashScreen() { setTimeout(() => { const splash = document.getElementById('splashScreen'); splash.style.opacity = '0'; setTimeout(() => { splash.style.display = 'none'; init(); }, 1000); }, 2500); }
        window.addEventListener('beforeunload', function (e) { saveGame(); });
        document.addEventListener('visibilitychange', function() { if (document.visibilityState === 'hidden') saveGame(); });
        window.onload = showSplashScreen;
    </script>
</body>
</html></pre>
        </body>
    </html>
