<html>
        <head><title>Downloaded HTML</title></head>
        <body>
            <pre style="white-space: pre-wrap; word-wrap: break-word;"><!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>PMK Run</title>
    <style>
        html,body{margin:0;padding:0;width:100%;height:100%;overflow:hidden;background-color:#000;font-family:'Segoe UI',Tahoma,sans-serif;touch-action:none;}
        #gameCanvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;}
        #gameCanvas canvas{display:block;width:100%!important;height:100%!important;outline:none;}
        .ui-layer{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;display:flex;flex-direction:column;justify-content:space-between;z-index:10;}
        .hud{padding:20px;display:flex;justify-content:space-between;color:white;font-size:24px;font-weight:bold;text-shadow:2px 2px 4px rgba(0,0,0,0.8);z-index:10;pointer-events:auto;}
        .coin-text{color:#FFD700;} .diamond-text{color:#00e5ff;margin-left:15px;}
        .total-coins-menu{position:absolute;top:15px;right:15px;background:rgba(0,0,0,0.7);padding:8px 15px;border-radius:20px;color:#FFD700;font-weight:bold;font-size:14px;border:2px solid #FFD700;display:flex;gap:10px;z-index:10;}
        .settings-btn-small{position:absolute;top:15px;left:15px;background:rgba(0,0,0,0.7);border:2px solid #2196F3;color:white;border-radius:50%;width:38px;height:38px;font-size:18px;cursor:pointer;display:flex;justify-content:center;align-items:center;z-index:11;transition:transform 0.2s;box-shadow:0 2px 5px rgba(0,0,0,0.5);}
        .settings-btn-small:hover{transform:scale(1.1);} .settings-btn-small:active{transform:scale(0.9);}
        .powerup-hud{display:none;background:linear-gradient(45deg,#ff007f,#7f00ff);padding:5px 15px;border-radius:20px;margin-top:10px;font-size:16px;text-align:center;box-shadow:0 0 10px #ff007f;animation:pulse 1s infinite;}
        .locked-char{filter:grayscale(100%) brightness(50%);}
        .price-tag{color:#FFD700;font-size:12px;font-weight:bold;display:block;}
        @keyframes pulse{0%{transform:scale(1);}50%{transform:scale(1.05);}100%{transform:scale(1);}}
        .menu{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.85);padding:25px;border-radius:20px;text-align:center;color:white;pointer-events:auto;box-shadow:0 0 20px rgba(255,255,255,0.2);width:85%;max-width:450px;backdrop-filter:blur(5px);max-height:95vh;overflow:hidden;}
        .selector::-webkit-scrollbar{width:6px;} .selector::-webkit-scrollbar-track{background:rgba(0,0,0,0.2);border-radius:10px;} .selector::-webkit-scrollbar-thumb{background:#4CAF50;border-radius:10px;}
        h1{margin-top:0;color:#4CAF50;font-size:28px;margin-bottom:10px;}
        #mainMenu h1{margin-top:25px;margin-bottom:5px;color:#ff69b4;font-size:30px;text-shadow:2px 2px 6px rgba(0,0,0,0.9);letter-spacing:2px;font-weight:900;}
        .menu-section{margin-bottom:15px;text-align:left;} .menu-section h3{margin:5px 0;font-size:16px;color:#aaa;}
        .carousel-wrapper{display:flex;align-items:center;justify-content:center;gap:15px;margin-top:5px;}
        .carousel-btn{background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.3);color:white;font-size:20px;padding:10px;border-radius:50%;cursor:pointer;width:45px;height:45px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;box-shadow:0 4px 10px rgba(0,0,0,0.5);}
        .carousel-btn:active{background:rgba(255,255,255,0.4);transform:scale(0.9);}
        .char-preview-box{position:relative;width:200px;height:150px;border-radius:20px;background:radial-gradient(circle at 50% 50%,#444 0%,#111 100%);display:flex;justify-content:center;align-items:center;border:3px solid #555;transition:all 0.3s cubic-bezier(0.175,0.885,0.32,1.275);box-shadow:inset 0 -20px 30px rgba(0,0,0,0.8),0 10px 20px rgba(0,0,0,0.6);}
        .char-preview-box.premium{border-color:#00e5ff;background:radial-gradient(circle at 50% 50%,rgba(0,229,255,0.2) 0%,#111 100%);box-shadow:0 0 20px rgba(0,229,255,0.5),inset 0 -20px 30px rgba(0,0,0,0.8);animation:premiumPulse 2s infinite;}
        .char-preview-box.locked{filter:grayscale(100%) brightness(40%);border-color:#333;}
        #menuCharCanvasContainer{width:100%;height:100%;border-radius:17px;overflow:hidden;position:relative;z-index:1;}
        .lock-icon-overlay{position:absolute;top:50%;left:35%;transform:translate(-50%,-50%);font-size:45px;text-shadow:0 2px 10px rgba(0,0,0,0.9);z-index:5;}
        .char-info-box{text-align:center;margin:8px auto 0 auto;background:rgba(0,0,0,0.4);padding:8px;border-radius:12px;border:1px solid rgba(255,255,255,0.1);width:85%;}
        .char-title{font-size:16px;font-weight:bold;margin:0;color:#fff;text-shadow:1px 1px 3px #000;} .char-desc{font-size:11px;color:#00e5ff;margin:3px 0 6px 0;min-height:14px;font-style:italic;}
        .costume-btn{padding:4px 10px;border-radius:15px;font-size:11px;font-weight:bold;cursor:pointer;transition:all 0.2s;} .costume-btn:hover{transform:scale(1.05);} .costume-btn:active{transform:scale(0.95);}
        .map-preview-box{position:relative;width:180px;height:120px;border-radius:15px;display:flex;justify-content:center;align-items:center;border:3px solid #555;transition:all 0.3s ease;box-shadow:0 10px 20px rgba(0,0,0,0.6);overflow:hidden;background:#111;}
        .map-preview-box img{width:100%;height:100%;object-fit:cover;transition:all 0.3s ease;image-rendering:pixelated;}
        .map-preview-box.premium{border-color:#00e5ff;box-shadow:0 0 20px rgba(0,229,255,0.5);} .map-preview-box.locked img{filter:grayscale(100%) brightness(40%);}
        .map-info-text{font-size:12px;color:#ccc;margin:4px 0;} .map-info-text span{color:#fff;font-weight:bold;}
        .selector{display:grid;grid-template-columns:repeat(3,1fr);justify-items:center;gap:10px;padding:10px 0;}
        .item-card{background:linear-gradient(145deg,rgba(60,60,60,0.9),rgba(30,30,30,0.9));padding:12px 5px 10px 5px;border-radius:18px;width:100%;max-width:110px;box-sizing:border-box;text-align:center;border:2px solid #444;cursor:pointer;transition:all 0.4s ease;position:relative;}
        .item-card.active{border-color:#00e676;background:linear-gradient(145deg,rgba(0,230,118,0.2),rgba(0,0,0,0.8));transform:translateY(-8px) scale(1.05);box-shadow:0 10px 20px rgba(0,230,118,0.3);}
        .item-card:hover:not(.active){transform:translateY(-3px);border-color:#888;}
        .item-card img{width:100%;max-width:56px;aspect-ratio:1/1;image-rendering:pixelated;border-radius:50%;border:3px solid #555;background:radial-gradient(circle at 30% 30%,#888,#222);box-shadow:inset 0 0 10px rgba(0,0,0,0.8),0 5px 10px rgba(0,0,0,0.5);transition:all 0.4s ease;object-fit:cover;}
        .item-card.active img{border-color:#00e676;box-shadow:0 0 20px rgba(0,230,118,0.8),inset 0 0 10px rgba(0,0,0,0.5);transform:rotate(8deg) scale(1.15);}
        .item-name{font-weight:bold;font-size:12px;margin-top:8px;display:block;text-shadow:1px 1px 2px #000;}
        .price-tag{background:rgba(0,0,0,0.8);padding:3px 6px;border-radius:10px;margin-top:6px;color:#FFD700;font-size:11px;font-weight:bold;display:inline-block;border:1px solid #FFD700;box-shadow:0 2px 5px rgba(0,0,0,0.5);}
        .price-tag.diamond{color:#00e5ff;border-color:#00e5ff;}
        button.play-btn{background:#4CAF50;color:white;border:none;padding:12px 20px;font-size:18px;border-radius:30px;cursor:pointer;font-weight:bold;box-shadow:0 5px 15px rgba(76,175,80,0.4);width:100%;margin-top:8px;transition: transform 0.2s;}
        button.play-btn:active{transform:scale(0.95);} button.play-btn:disabled{background:#555 !important; cursor:not-allowed; box-shadow:none;}
        .start-game-btn{margin-top:10px;margin-bottom:5px;font-size:20px;padding:15px;}
        #gameOverMenu{display:none;} .controls-hint{font-size:13px;color:#ccc;margin-top:10px;line-height:1.4;}
        .toggle-btn{padding:8px 20px;border-radius:20px;border:2px solid white;color:white;font-weight:bold;cursor:pointer;transition:all 0.3s;}
        .lang-btn{padding:5px 15px;border-radius:10px;border:1px solid white;color:white;cursor:pointer;margin-left:5px;}
        .pause-btn{position:absolute;bottom:30px;left:20px;background:rgba(0,0,0,0.6);border:2px solid white;color:white;border-radius:50%;width:50px;height:50px;cursor:pointer;font-size:24px;display:flex;justify-content:center;align-items:center;padding:0;margin:0;box-shadow:0 4px 8px rgba(0,0,0,0.5);pointer-events:auto;}

        .mission-item { background: rgba(0,0,0,0.6); padding: 12px; border-radius: 10px; margin-bottom: 8px; border-left: 4px solid #2196F3; display: flex; justify-content: space-between; align-items: center; text-align: left;}
        .mission-info { flex: 1; margin-right: 10px; }
        .mission-title { font-weight: bold; font-size: 13px; margin-bottom: 4px; display: block; color: white;}
        .mission-prog { font-size: 11px; color: #aaa; }
        .btn-claim { background: #4CAF50; color: white; border: none; padding: 8px 12px; border-radius: 15px; font-weight: bold; font-size: 12px; cursor: pointer; transition: 0.2s;}
        .btn-claim:active { transform: scale(0.9); }
        .btn-claim:disabled { background: #444; color: #888; cursor: not-allowed; }

        @media (max-width:600px){
            .menu{width:95%;padding:12px 10px;max-height:98vh;} #mainMenu h1{font-size:24px;margin-top:15px;margin-bottom:5px;}
            .char-preview-box{width:180px;height:130px;} .carousel-btn{width:35px;height:35px;font-size:16px;padding:5px;}
            button.play-btn{padding:8px 15px;font-size:15px;margin:4px 0;} .start-game-btn{padding:10px 15px;font-size:16px;margin:5px 0;}
            .hud{padding:15px;font-size:20px;} .pause-btn{bottom:15px;left:15px;width:40px;height:40px;font-size:18px;}
            .total-coins-menu{top:10px;right:10px;font-size:12px;padding:5px 10px;}
            .item-card{padding:8px 4px 5px 4px;border-radius:12px;}
            .item-card img{max-width:45px;border-width:2px;} .item-name{font-size:10px;margin-top:5px;} .price-tag{font-size:10px;padding:2px 4px;margin-top:4px;}
            .selector{gap:8px;} .settings-btn-small{top:10px;left:10px;width:32px;height:32px;font-size:16px;} .controls-hint{font-size:10px;margin-top:4px;line-height:1.2;}
        }
        #loading{position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle at center,#2b0057 0%,#000 100%);display:flex;justify-content:center;align-items:center;z-index:9999;flex-direction:column;}
        .loading-content{text-align:center;width:80%;max-width:400px;}
        .loading-title{color:#ff69b4;font-size:45px;margin-bottom:30px;text-shadow:0 0 15px #ff69b4,2px 2px 5px #000;font-weight:900;letter-spacing:3px;animation:pulse 1.5s infinite;}
        .loading-bar-container{width:100%;height:20px;background:#222;border-radius:10px;border:2px solid #555;overflow:hidden;margin-bottom:10px;box-shadow:0 0 15px rgba(0,229,255,0.4);}
        .loading-bar{width:0%;height:100%;background:linear-gradient(90deg,#00e5ff,#aa00ff);transition:width 0.2s ease-out;}
        .loading-text{color:#00e5ff;font-size:14px;font-weight:bold;font-family:monospace;}
        #blurOverlay{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:5;display:none;backdrop-filter:blur(8px) contrast(1.2);background:rgba(50,0,50,0.2);}
        #stepTutorial{display:none;position:absolute;top:25%;left:50%;transform:translateX(-50%);background:transparent;padding:15px 30px;border-radius:0;border:none;color:white;font-size:22px;font-weight:bold;text-align:center;z-index:100;text-shadow:2px 2px 8px #000,0 0 15px #00e5ff;pointer-events:none;transition:opacity 0.3s;}
        #tutStepIcon{font-size:60px;margin-bottom:5px;animation:pulse 1s infinite;filter:drop-shadow(2px 2px 5px #000);}
        #splashScreen{position:fixed;top:0;left:0;width:100%;height:100%;background-color:#ffffff;display:flex;justify-content:center;align-items:center;z-index:100000;transition:opacity 1s ease-out;}
        #splashScreen img{max-width:80%;max-height:50%;animation:splashPulse 1.5s infinite alternate;}
        @keyframes splashPulse{0%{transform:scale(0.95);}100%{transform:scale(1.05);}}
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>
    <div id="splashScreen">
        <img src="Polish_20260422_201218507.png" alt="MRD Game Logo" onerror="this.style.display='none'; document.getElementById('fallbackLogo').style.display='block';">
        <h1 id="fallbackLogo" style="display:none; color: #2196F3; font-size: 60px; font-weight: 900; text-shadow: 2px 2px 10px rgba(0,0,0,0.2); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; letter-spacing: 2px; animation: splashPulse 1.5s infinite alternate;">MRD GAME</h1>
    </div>

    <div id="loading">
        <div class="loading-content">
            <div class="loading-title">PMK RUN</div>
            <div class="loading-bar-container"><div class="loading-bar" id="loadingBar"></div></div>
            <div class="loading-text" id="loadingText">Memuat Engine... 0%</div>
        </div>
    </div>

    <div id="gameCanvas"></div>

    <div class="ui-layer">
        <div id="blurOverlay"></div>
        <div id="stepTutorial"><div id="tutStepIcon">👈</div><div id="tutStepText">Geser KIRI<br>untuk pindah jalur</div></div>
        <div id="countdownOverlay" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; justify-content: center; align-items: center; z-index: 200; font-size: 150px; color: white; font-weight: bold; text-shadow: 0 0 20px #00e5ff, 4px 4px 10px #000; pointer-events: none; animation: pulse 1s infinite;">3</div>
        <div class="hud" id="hud" style="display: none;">
            <div><div id="scoreDisplay">Jarak: 0m</div><div id="powerupDisplay" class="powerup-hud">⚡ SPEED BOOST</div></div>
            <div style="display: flex; flex-direction: column; align-items: flex-end;"><span id="coinDisplay" class="coin-text">🪙 0</span><span id="diamondDisplay" class="diamond-text">💎 0</span></div>
            <button id="pauseBtn" onclick="togglePause()" class="pause-btn">⏸️</button>
        </div>

        <div id="warningDisplay" style="display: none; position: absolute; top: 80px; left: 50%; transform: translateX(-50%); background: rgba(255,0,0,0.8); color: white; padding: 5px 15px; border-radius: 10px; font-weight: bold; z-index: 100; text-align: center; font-size: 16px; border: 2px solid white; animation: pulse 0.5s infinite;">⚠️ MUSUH MENDEKAT!</div>

        <!-- MAIN MENU -->
        <div class="menu" id="mainMenu">
            <button class="settings-btn-small" onclick="openSettings()" title="Pengaturan">⚙️</button>
            <div class="total-coins-menu"><span id="menuTotalCoins">🪙 0</span><span id="menuTotalDiamonds" style="color:#00e5ff;">💎 0</span></div>
            <h1>PMK Run</h1>
            
            <button id="btnStartGame" class="play-btn start-game-btn" onclick="startGame()">Mulai Lari!</button>
            <button id="btnOpenMissions" class="play-btn" onclick="openMissionMenu()" style="background: #2196F3; margin-bottom: 8px;">📜 Daftar Misi</button>
            <button id="btnOpenShop" class="play-btn" onclick="openShopMenu()" style="background: #FF9800; margin-bottom: 8px;">🛒 Shop Karakter</button>
            <button id="btnMapSelect" class="play-btn" onclick="openMapMenu()" style="background: #9C27B0; margin-bottom: 8px;">🌍 Lokasi: <span id="currentMapBtnText">Hutan Tropis</span></button>
            
            <div class="controls-hint" style="color: #ff4444; font-weight: bold; font-size: 15px; text-transform: uppercase; animation: pulse 1s infinite; text-shadow: 1px 1px 3px #000;">
                hawas jangan sampai tertangkap banci kerudung
            </div>
        </div>

        <!-- MISSION MENU -->
        <div class="menu" id="missionMenu" style="display: none; z-index: 100;">
            <button class="settings-btn-small" onclick="closeMissionMenu()" style="border-color: #f44336; left: 15px; top: 15px; background: rgba(0,0,0,0.8);">⬅️</button>
            <div class="total-coins-menu"><span id="missionTotalCoins">🪙 0</span><span id="missionTotalDiamonds" style="color:#00e5ff;">💎 0</span></div>
            <h1 style="color: #2196F3; margin-top: 25px;">Daftar Misi</h1>
            <div id="missionListContainer" style="max-height: 55vh; overflow-y: auto; padding-right: 5px; margin-top: 15px;"></div>
        </div>

        <!-- DAILY GIFT MODAL -->
        <div class="menu" id="dailyGiftModal" style="display: none; z-index: 110; padding: 30px 20px;">
            <button class="settings-btn-small" onclick="closeDailyGiftModal()" style="border-color: #f44336; left: 15px; top: 15px; background: rgba(0,0,0,0.8);">✖</button>
            <h2 style="color: #FFD700; margin-top: 20px;">🎁 Hadiah Harian!</h2>
            <p style="color: white; font-size: 14px; margin-bottom: 20px;">Klaim hadiah gratis Anda hari ini!</p>
            <button id="btnClaimDaily" class="play-btn" onclick="executeClaimDaily()" style="background: #FFD700; color: #000;">Klaim Sekarang</button>
        </div>

        <!-- SHOP MENU -->
        <div class="menu" id="shopMenu" style="display: none; z-index: 100;">
            <button class="settings-btn-small" onclick="closeShopMenu()" style="border-color: #f44336; left: 15px; top: 15px; z-index: 11; background: rgba(0,0,0,0.8);">⬅️</button>
            <div class="total-coins-menu"><span id="shopTotalCoins">🪙 0</span><span id="shopTotalDiamonds" style="color:#00e5ff;">💎 0</span></div>
            <h1 style="color: #FFC107; margin-top: 25px;">Shop Karakter</h1>
            
            <div class="menu-section" style="margin-bottom: 0;">
                <div class="carousel-wrapper" style="margin-top: 0;">
                    <button class="carousel-btn" onclick="prevChar()">&#10094;</button>
                    <div id="charPreviewBox" class="char-preview-box">
                        <div id="menuCharCanvasContainer"></div>
                        <div id="charLockOverlayCarousel" class="lock-icon-overlay">🔒</div>
                    </div>
                    <button class="carousel-btn" onclick="nextChar()">&#10095;</button>
                </div>
                <div class="char-info-box" style="margin-top: 5px;">
                    <h4 id="carouselCharName" class="char-title">Nama Karakter</h4>
                    <p id="carouselCharDesc" class="char-desc" style="margin: 2px 0;">&nbsp;</p>
                    <div id="costumeSelector" style="display: flex; gap: 5px; justify-content: center; margin-bottom: 5px; flex-wrap: wrap;"></div>
                    <button id="btnCharAction" class="play-btn" style="margin-top: 0; font-size: 14px; padding: 6px 20px; width: auto; min-width: 120px;">Pilih</button>
                </div>
            </div>
        </div>

        <!-- MAP MENU -->
        <div class="menu" id="mapMenu" style="display: none; z-index: 100;">
            <button class="settings-btn-small" onclick="closeMapMenu()" style="border-color: #f44336; left: 15px; top: 15px; background: rgba(0,0,0,0.8);">⬅️</button>
            <h1 style="color: #2196F3; margin-top: 20px;">Pilih Lokasi</h1>
            <div class="selector" id="mapSelectGrid" style="max-height: 60vh; overflow-y: auto;"></div>
        </div>

        <!-- SETTINGS MENU -->
        <div class="menu" id="settingsMenu" style="display: none; z-index: 100;">
            <button class="settings-btn-small" onclick="closeSettings()" style="border-color: #f44336; left: 15px; top: 15px; background: rgba(0,0,0,0.8);">⬅️</button>
            <h1 id="txtSettingsTitle" style="color: #2196F3; margin-top: 20px;">Pengaturan</h1>
            <div class="menu-section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <span id="txtSound" style="font-size: 16px;">Suara Efek (SFX)</span>
                    <button id="btnSound" class="toggle-btn" onclick="toggleSound()">ON</button>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <span id="txtMusic" style="font-size: 16px;">Musik Latar</span>
                    <button id="btnMusic" class="toggle-btn" onclick="toggleMusic()">ON</button>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <span id="txtLang" style="font-size: 16px;">Bahasa / Language</span>
                    <div>
                        <button id="btnLangID" class="lang-btn" onclick="setLanguage('id')">ID</button>
                        <button id="btnLangEN" class="lang-btn" onclick="setLanguage('en')">EN</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="menu" id="pauseMenu" style="display: none; z-index: 100;">
            <h1 style="color: #FFC107;">JEDA</h1>
            <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
                <button class="play-btn" onclick="togglePause()" style="background: #4CAF50; margin: 0;">▶️ Lanjutkan</button>
                <button class="play-btn" onclick="restartFromPause()" style="background: #FF9800; margin: 0;">🔄 Restart</button>
                <button class="play-btn" onclick="quitFromPause()" style="background: #f44336; margin: 0;">🚪 Keluar</button>
            </div>
        </div>

        <div class="menu" id="gameOverMenu">
            <h1 style="color: #ff4444;">GAME OVER</h1>
            <h2 id="finalScore">Jarak: 0m</h2>
            <h3 id="finalCoins" class="coin-text">Koin: 0</h3>
            <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                <button id="btnContinueDiamond" class="play-btn" onclick="continueGame()" style="background: #00e5ff; color: #000; font-size: 16px; margin: 0; min-width: 200px;">Bangkit (5 💎)</button>
            </div>
            <button class="play-btn" onclick="resetGame()" style="background: #2196F3; margin-top: 15px;">Main Lagi</button>
            <button class="play-btn" onclick="backToMenu()" style="background: #555; margin-top: 10px;">Menu Utama</button>
        </div>

        <div class="menu" id="customAlert" style="display: none; z-index: 9999;">
            <h3 id="alertMessage" style="color: white; margin-bottom: 20px; font-size: 18px; line-height: 1.5;">Pesan</h3>
            <div style="display: flex; gap: 10px; justify-content: center;">
                <button id="btnAlertOk" class="play-btn" style="padding: 10px 20px; font-size: 16px; margin: 0; width: 100%;">OK</button>
                <button id="btnAlertCancel" class="play-btn" style="background: #ff4444; padding: 10px 20px; font-size: 16px; margin: 0; width: 100%; display: none;">Batal</button>
            </div>
        </div>
    </div>

    <script>
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        let menuBgmInterval = null;
        let menuNoteIndex = 0;
        const menuNotes = [261.63, 329.63, 392.00, 523.25, 392.00, 329.63, 261.63, 196.00];
        
        function playMenuBgm() {
            if (typeof savedData !== 'undefined' && !savedData.settings.music) return;
            stopMenuBgm();
            if (audioCtx.state === 'suspended') audioCtx.resume();
            menuBgmInterval = setInterval(() => {
                if (audioCtx.state === 'suspended' || isPlaying) return; 
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(menuNotes[menuNoteIndex], audioCtx.currentTime);
                gain.gain.setValueAtTime(0, audioCtx.currentTime);
                gain.gain.linearRampToValueAtTime(0.15, audioCtx.currentTime + 0.1); 
                gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.4);
                osc.connect(gain); gain.connect(audioCtx.destination);
                osc.start(audioCtx.currentTime); osc.stop(audioCtx.currentTime + 0.4);
                menuNoteIndex = (menuNoteIndex + 1) % menuNotes.length;
            }, 400);
        }
        
        function stopMenuBgm() {
            if(menuBgmInterval) { clearInterval(menuBgmInterval); menuBgmInterval = null; }
        }

        function playSound(type) {
            if (typeof savedData !== 'undefined' && !savedData.settings.sound) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            osc.connect(gainNode); gainNode.connect(audioCtx.destination);
            const now = audioCtx.currentTime;
            if (type === 'jump') {
                osc.type = 'sine'; osc.frequency.setValueAtTime(300, now); osc.frequency.exponentialRampToValueAtTime(600, now + 0.1);
                gainNode.gain.setValueAtTime(0.3, now); gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
                osc.start(now); osc.stop(now + 0.2);
            } else if (type === 'coin') {
                osc.type = 'square'; osc.frequency.setValueAtTime(800, now); osc.frequency.setValueAtTime(1200, now + 0.05);
                gainNode.gain.setValueAtTime(0.1, now); gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
                osc.start(now); osc.stop(now + 0.1);
            } else if (type === 'diamond') {
                osc.type = 'sine'; osc.frequency.setValueAtTime(1200, now); osc.frequency.exponentialRampToValueAtTime(2000, now + 0.2);
                gainNode.gain.setValueAtTime(0.2, now); gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
                osc.start(now); osc.stop(now + 0.3);
            } else if (type === 'crash') {
                osc.type = 'sawtooth'; osc.frequency.setValueAtTime(100, now); osc.frequency.exponentialRampToValueAtTime(10, now + 0.3);
                gainNode.gain.setValueAtTime(0.3, now); gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
                osc.start(now); osc.stop(now + 0.3);
            } else if (type === 'select') {
                osc.type = 'sine'; osc.frequency.setValueAtTime(800, now); osc.frequency.exponentialRampToValueAtTime(1200, now + 0.1);
                gainNode.gain.setValueAtTime(0.1, now); gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
                osc.start(now); osc.stop(now + 0.1);
            }
        }

        let ambientNodes = [], ambientIntervals = [], currentRainGain = null;
        function stopAmbient() {
            ambientNodes.forEach(node => { try { if(node.stop) node.stop(); node.disconnect(); } catch(e){} });
            ambientNodes = []; ambientIntervals.forEach(clearInterval); ambientIntervals = [];
        }

        function startAmbient(mapId) {
            stopAmbient(); currentRainGain = null; 
            if (typeof savedData !== 'undefined' && !savedData.settings.music) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const bufferSize = audioCtx.sampleRate * 2;
            const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const output = noiseBuffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) output[i] = Math.random() * 2 - 1;

            function playNoise(type, freq, gainValue) {
                const noise = audioCtx.createBufferSource(); noise.buffer = noiseBuffer; noise.loop = true;
                const filter = audioCtx.createBiquadFilter(); filter.type = type; filter.frequency.value = freq;
                const gain = audioCtx.createGain(); gain.gain.value = gainValue;
                noise.connect(filter); filter.connect(gain); gain.connect(audioCtx.destination);
                noise.start(); ambientNodes.push(noise, filter, gain);
                return { noise, filter, gain };
            }

            if (mapId === 'gurun') {
                const wind = playNoise('lowpass', 400, 0.5);
                ambientIntervals.push(setInterval(() => {
                    const stormIntensity = 1 - sandstormTransition; 
                    if(wind.filter) wind.filter.frequency.linearRampToValueAtTime(200+(200*stormIntensity) + Math.random()*(400*stormIntensity), audioCtx.currentTime + 2);
                    if(wind.gain) wind.gain.gain.linearRampToValueAtTime(0.05+(0.25*stormIntensity) + Math.random()*(0.4*stormIntensity), audioCtx.currentTime + 2);
                }, 2000));
            } else if (mapId === 'sungai') {
                playNoise('lowpass', 800, 0.2); 
                currentRainGain = playNoise('lowpass', 1200, 0.3).gain;
                ambientIntervals.push(setInterval(() => { if(Math.random() > 0.4) playCricket(); }, 3000));
            } else if (mapId === 'hutan') {
                playNoise('lowpass', 250, 0.1); 
                currentRainGain = playNoise('lowpass', 1200, 0).gain;
                ambientIntervals.push(setInterval(() => { if(Math.random() > 0.3) playBird(); }, 4000));
                ambientIntervals.push(setInterval(() => { if(Math.random() > 0.5) playCricket(); }, 5000));
            } else if (mapId === 'desa') {
                playNoise('lowpass', 150, 0.05); 
                currentRainGain = playNoise('lowpass', 1200, 0).gain;
                ambientIntervals.push(setInterval(() => { if(Math.random() > 0.4) playBird(); }, 6000));
                ambientIntervals.push(setInterval(() => playCricket(), 4000));
            } else if (mapId === 'kota') {
                const osc = audioCtx.createOscillator(); osc.type = 'sawtooth'; osc.frequency.value = 50;
                const filter = audioCtx.createBiquadFilter(); filter.type = 'lowpass'; filter.frequency.value = 150;
                const gain = audioCtx.createGain(); gain.gain.value = 0.05;
                osc.connect(filter); filter.connect(gain); gain.connect(audioCtx.destination); osc.start();
                ambientNodes.push(osc, filter, gain);
                ambientIntervals.push(setInterval(() => { if(Math.random() > 0.6) playHorn(); }, 4000));
            } else if (mapId === 'rel') {
                playNoise('lowpass', 250, 0.15); 
                ambientIntervals.push(setInterval(() => playTrainClack(), 1200)); 
            } else if (mapId === 'fantasi') {
                playNoise('lowpass', 600, 0.1);
                ambientIntervals.push(setInterval(() => {
                    if(Math.random() > 0.3) {
                        const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                        osc.type = 'sine'; osc.frequency.setValueAtTime(800 + Math.random()*1000, audioCtx.currentTime);
                        gain.gain.setValueAtTime(0, audioCtx.currentTime); gain.gain.linearRampToValueAtTime(0.05, audioCtx.currentTime + 0.5); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 2);
                        osc.connect(gain); gain.connect(audioCtx.destination);
                        osc.start(); osc.stop(audioCtx.currentTime + 2);
                    }
                }, 2000));
            } else if (mapId === 'lava') {
                playNoise('lowpass', 300, 0.3);
                ambientIntervals.push(setInterval(() => {
                    if(Math.random() > 0.4) {
                        const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                        osc.type = 'sawtooth'; osc.frequency.setValueAtTime(50 + Math.random()*50, audioCtx.currentTime);
                        gain.gain.setValueAtTime(0, audioCtx.currentTime); gain.gain.linearRampToValueAtTime(0.2, audioCtx.currentTime + 0.1); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.8);
                        osc.connect(gain); gain.connect(audioCtx.destination);
                        osc.start(); osc.stop(audioCtx.currentTime + 0.8);
                    }
                }, 1500));
            }
        }

        function playBird() {
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.type = 'sine'; osc.frequency.setValueAtTime(2000+Math.random()*1000, audioCtx.currentTime); osc.frequency.exponentialRampToValueAtTime(3000+Math.random()*1000, audioCtx.currentTime + 0.2);
            gain.gain.setValueAtTime(0, audioCtx.currentTime); gain.gain.linearRampToValueAtTime(0.03, audioCtx.currentTime + 0.05); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.2);
            osc.connect(gain); gain.connect(audioCtx.destination); osc.start(); osc.stop(audioCtx.currentTime + 0.2);
        }

        function playCricket() {
            const playChirp = (delay) => {
                const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                osc.type = 'square'; osc.frequency.setValueAtTime(4000+Math.random()*500, audioCtx.currentTime + delay);
                gain.gain.setValueAtTime(0, audioCtx.currentTime + delay); gain.gain.linearRampToValueAtTime(0.015, audioCtx.currentTime + delay + 0.01); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + delay + 0.05);
                osc.connect(gain); gain.connect(audioCtx.destination); osc.start(audioCtx.currentTime + delay); osc.stop(audioCtx.currentTime + delay + 0.05);
            };
            playChirp(0); playChirp(0.1);
        }

        function playHorn() {
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.type = 'sawtooth'; osc.frequency.setValueAtTime(300+Math.random()*100, audioCtx.currentTime);
            gain.gain.setValueAtTime(0, audioCtx.currentTime); gain.gain.linearRampToValueAtTime(0.02, audioCtx.currentTime + 0.1); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.6);
            const filter = audioCtx.createBiquadFilter(); filter.type = 'lowpass'; filter.frequency.value = 800;
            osc.connect(filter); filter.connect(gain); gain.connect(audioCtx.destination); osc.start(); osc.stop(audioCtx.currentTime + 0.6);
        }

        function playTrainClack() {
            if(!isPlaying) return;
            const playHit = (delay) => {
                const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                osc.type = 'square'; osc.frequency.setValueAtTime(100, audioCtx.currentTime + delay); osc.frequency.exponentialRampToValueAtTime(20, audioCtx.currentTime + delay + 0.05);
                gain.gain.setValueAtTime(0, audioCtx.currentTime + delay); gain.gain.linearRampToValueAtTime(0.03, audioCtx.currentTime + delay + 0.01); gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + delay + 0.05);
                const filter = audioCtx.createBiquadFilter(); filter.type = 'lowpass'; filter.frequency.value = 400;
                osc.connect(filter); filter.connect(gain); gain.connect(audioCtx.destination); osc.start(audioCtx.currentTime + delay); osc.stop(audioCtx.currentTime + delay + 0.05);
            };
            playHit(0); playHit(0.15); 
        }

        function showModal(msg, isConfirm, onConfirm) {
            document.getElementById('alertMessage').innerText = msg;
            const alertBox = document.getElementById('customAlert');
            const btnOk = document.getElementById('btnAlertOk');
            const btnCancel = document.getElementById('btnAlertCancel');
            alertBox.style.display = 'block';
            if(isConfirm) {
                btnCancel.style.display = 'block'; btnOk.innerText = 'Beli';
                btnOk.onclick = () => { alertBox.style.display = 'none'; if(onConfirm) onConfirm(); };
                btnCancel.onclick = () => { alertBox.style.display = 'none'; };
            } else {
                btnCancel.style.display = 'none'; btnOk.innerText = 'OK';
                btnOk.onclick = () => { alertBox.style.display = 'none'; if(onConfirm) onConfirm(); };
            }
        }

        function generateRandomMission(id) {
            const types = ['distance', 'coin', 'jump']; const type = types[Math.floor(Math.random() * types.length)];
            let desc, target, reward, rewardType;
            if (type === 'distance') { target = Math.floor(Math.random() * 4 + 1) * 500; desc = `Lari sejauh ${target}m`; rewardType = Math.random() > 0.7 ? 'diamond' : 'coin'; reward = rewardType === 'diamond' ? Math.floor(target/500) * 2 : target / 2; } 
            else if (type === 'coin') { target = Math.floor(Math.random() * 4 + 1) * 100; desc = `Kumpulkan ${target} Koin`; rewardType = Math.random() > 0.8 ? 'diamond' : 'coin'; reward = rewardType === 'diamond' ? Math.floor(target/100) * 2 : target; } 
            else { target = Math.floor(Math.random() * 4 + 1) * 20; desc = `Lompat ${target} Kali`; rewardType = 'coin'; reward = target * 5; }
            return { id: id, desc: desc, type: type, target: target, progress: 0, reward: reward, rewardType: rewardType, claimed: false };
        }

        let savedData;
        try {
            const savedStr = localStorage.getItem('runnerSave');
            savedData = savedStr ? JSON.parse(savedStr) : null;
        } catch (e) {
            console.warn("Save file corrupt, creating new profile.");
            savedData = null;
        }

        if (!savedData) {
            savedData = {
                totalCoins: 0, totalDiamonds: 5, unlockedChars: ['tesya'], unlockedMaps: ['hutan', 'sungai', 'gurun', 'rel', 'kota', 'fantasi', 'desa', 'lava'], unlockedCostumes: {}, selectedCostumes: {},
                hasSeenTutorial: false, lastDailyGiftDate: '', missionsList: [
                    { id: 'm1', desc: "Lari sejauh 1000m", type: "distance", target: 1000, progress: 0, reward: 100, rewardType: "coin", claimed: false },
                    { id: 'm2', desc: "Kumpulkan 200 Koin", type: "coin", target: 200, progress: 0, reward: 10, rewardType: "diamond", claimed: false },
                    { id: 'm3', desc: "Lompat 50 Kali", type: "jump", target: 50, progress: 0, reward: 150, rewardType: "coin", claimed: false }
                ],
                settings: { sound: true, music: true, language: 'id' }
            };
        }
        if (savedData.totalDiamonds === undefined) savedData.totalDiamonds = 5;
        if (savedData.hasSeenTutorial === undefined) savedData.hasSeenTutorial = false;
        savedData.unlockedMaps = ['hutan', 'sungai', 'gurun', 'rel', 'kota', 'fantasi', 'desa', 'lava'];
        if (!savedData.unlockedCostumes) savedData.unlockedCostumes = {};
        if (!savedData.selectedCostumes) savedData.selectedCostumes = {};
        if (!savedData.settings) savedData.settings = { sound: true, music: true, language: 'id' };
        if (!savedData.missionsList || savedData.missionsList.length === 0) savedData.missionsList = [
            { id: 'm1', desc: "Lari sejauh 1000m", type: "distance", target: 1000, progress: 0, reward: 100, rewardType: "coin", claimed: false },
            { id: 'm2', desc: "Kumpulkan 200 Koin", type: "coin", target: 200, progress: 0, reward: 10, rewardType: "diamond", claimed: false },
            { id: 'm3', desc: "Lompat 50 Kali", type: "jump", target: 50, progress: 0, reward: 150, rewardType: "coin", claimed: false }
        ];

        savedData.missionsList.forEach((m, idx) => { if (m.claimed) savedData.missionsList[idx] = generateRandomMission(m.id); });

        function saveGame() { localStorage.setItem('runnerSave', JSON.stringify(savedData)); }

        function updateMenuCoinsDisplay() {
            const coinTxt = `🪙 ${savedData.totalCoins}`, diamondTxt = `💎 ${savedData.totalDiamonds}`;
            ['menuTotalCoins', 'shopTotalCoins', 'missionTotalCoins'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).innerText = coinTxt; });
            ['menuTotalDiamonds', 'shopTotalDiamonds', 'missionTotalDiamonds'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).innerText = diamondTxt; });
        }

        let hasAutoShownDaily = false;
        function openDailyGiftModal() {
            playSound('select'); const btn = document.getElementById('btnClaimDaily');
            if (savedData.lastDailyGiftDate === new Date().toDateString()) { btn.innerText = "Sudah Diambil"; btn.disabled = true; btn.style.background = "#555"; } 
            else { btn.innerText = "Klaim Sekarang"; btn.disabled = false; btn.style.background = "#FFD700"; }
            document.getElementById('dailyGiftModal').style.display = 'block';
        }
        function closeDailyGiftModal() { playSound('select'); document.getElementById('dailyGiftModal').style.display = 'none'; }
        function executeClaimDaily() {
            const today = new Date().toDateString(); if (savedData.lastDailyGiftDate === today) return;
            savedData.lastDailyGiftDate = today; const roll = Math.random(); let rewardMsg = "";
            if (roll < 0.6) { const coinReward = Math.floor(Math.random() * 151) + 50; savedData.totalCoins += coinReward; rewardMsg = `🎉 Anda mendapatkan ${coinReward} 🪙!`; } 
            else if (roll < 0.8) { const diamondReward = 3 + Math.floor(Math.random() * 8); savedData.totalDiamonds += diamondReward; rewardMsg = `🎉 Anda mendapatkan ${diamondReward} 💎!`; } 
            else { const coinReward = Math.floor(Math.random() * 101) + 100; const diamondReward = 5 + Math.floor(Math.random() * 5); savedData.totalCoins += coinReward; savedData.totalDiamonds += diamondReward; rewardMsg = `🎉 Jackpot! ${coinReward} 🪙 & ${diamondReward} 💎!`; }
            playSound('diamond'); saveGame(); updateMenuCoinsDisplay();
            const btn = document.getElementById('btnClaimDaily'); btn.innerText = "Sudah Diambil"; btn.disabled = true; btn.style.background = "#555";
            setTimeout(() => { showModal(rewardMsg, false, () => { closeDailyGiftModal(); }); }, 300);
        }

        function openMissionMenu() { playSound('select'); document.getElementById('mainMenu').style.display = 'none'; document.getElementById('missionMenu').style.display = 'block'; updateMenuCoinsDisplay(); renderMissions(); }
        function closeMissionMenu() { playSound('select'); document.getElementById('missionMenu').style.display = 'none'; document.getElementById('mainMenu').style.display = 'block'; }
        function renderMissions() {
            const container = document.getElementById('missionListContainer'); container.innerHTML = '';
            savedData.missionsList.forEach(m => {
                const div = document.createElement('div'); div.className = 'mission-item'; const rewardTxt = m.rewardType === 'diamond' ? `💎 ${m.reward}` : `🪙 ${m.reward}`; const isCompleted = m.progress >= m.target;
                let btnHtml = '';
                if (m.claimed) { btnHtml = `<button class="btn-claim" disabled style="background:#555;">Selesai</button>`; } 
                else if (isCompleted) { btnHtml = `<button class="btn-claim" onclick="claimMission('${m.id}')" style="background:#FF9800;">Klaim</button>`; } 
                else { btnHtml = `<button class="btn-claim" disabled>${m.progress}/${m.target}</button>`; }
                div.innerHTML = `<div class="mission-info"><span class="mission-title">${m.desc}</span><span class="mission-prog">Hadiah: <b style="color:${m.rewardType === 'diamond' ? '#00e5ff' : '#FFD700'}">${rewardTxt}</b></span></div>${btnHtml}`;
                container.appendChild(div);
            });
        }
        function claimMission(missionId) {
            playSound('diamond'); const missionIndex = savedData.missionsList.findIndex(m => m.id === missionId);
            if (missionIndex !== -1) {
                const mission = savedData.missionsList[missionIndex];
                if (!mission.claimed && mission.progress >= mission.target) {
                    if (mission.rewardType === 'diamond') savedData.totalDiamonds += mission.reward; else savedData.totalCoins += Math.floor(mission.reward);
                    savedData.missionsList[missionIndex] = generateRandomMission(missionId);
                    saveGame(); updateMenuCoinsDisplay(); renderMissions();
                }
            }
        }

        const i18n = {
            id: { settingsTitle: "Pengaturan", sound: "Suara Efek (SFX)", music: "Musik Latar", lang: "Bahasa / Language", close: "Tutup", chooseChar: "Pilih Karakter:", mapLoc: "🌍 Lokasi: ", playBtn: "Mulai Lari!", hintLR: "Kanan/Kiri:", hintLRDesc: "Pindah Jalur", hintUp: "Rintangan Pendek/Lubang:", hintUpDesc: "LOMPAT (Atas)", hintDown: "Barikade/Portal:", hintDownDesc: "SLIDE (Bawah)", btnSelect: "Pilih", btnSelected: "✅ Dipilih", btnBuy: "Beli" },
            en: { settingsTitle: "Settings", sound: "Sound Effects (SFX)", music: "Background Music", lang: "Language / Bahasa", close: "Close", chooseChar: "Choose Character:", mapLoc: "🌍 Map: ", playBtn: "Start Run!", hintLR: "Right/Left:", hintLRDesc: "Switch Lanes", hintUp: "Short Obstacle/Hole:", hintUpDesc: "JUMP (Swipe Up)", hintDown: "Barricade/Portal:", hintDownDesc: "SLIDE (Swipe Down)", btnSelect: "Select", btnSelected: "✅ Selected", btnBuy: "Buy" }
        };

        function openSettings() { playSound('select'); document.getElementById('mainMenu').style.display = 'none'; document.getElementById('settingsMenu').style.display = 'block'; updateSettingsUI(); }
        function closeSettings() { playSound('select'); document.getElementById('settingsMenu').style.display = 'none'; document.getElementById('mainMenu').style.display = 'block'; applyLanguage(); }
        function toggleSound() { savedData.settings.sound = !savedData.settings.sound; saveGame(); playSound('select'); updateSettingsUI(); }
        function toggleMusic() { savedData.settings.music = !savedData.settings.music; saveGame(); playSound('select'); if(savedData.settings.music){ if(!isPlaying) playMenuBgm(); } else { stopMenuBgm(); stopAmbient(); } updateSettingsUI(); }
        function setLanguage(lang) { savedData.settings.language = lang; saveGame(); playSound('select'); updateSettingsUI(); applyLanguage(); }
        
        function updateSettingsUI() {
            const s = savedData.settings; const btnS = document.getElementById('btnSound'); const btnM = document.getElementById('btnMusic');
            btnS.innerText = s.sound ? "ON" : "OFF"; btnS.className = s.sound ? "toggle-btn active" : "toggle-btn"; btnS.style.background = s.sound ? "#4CAF50" : "#f44336";
            btnM.innerText = s.music ? "ON" : "OFF"; btnM.className = s.music ? "toggle-btn active" : "toggle-btn"; btnM.style.background = s.music ? "#4CAF50" : "#f44336";
            document.getElementById('btnLangID').className = s.language === 'id' ? "lang-btn active" : "lang-btn"; document.getElementById('btnLangEN').className = s.language === 'en' ? "lang-btn active" : "lang-btn";
            document.getElementById('btnLangID').style.background = s.language === 'id' ? "#2196F3" : "#555"; document.getElementById('btnLangEN').style.background = s.language === 'en' ? "#2196F3" : "#555";
        }

        function applyLanguage() {
            const lang = savedData.settings.language || 'id'; const text = i18n[lang];
            const setTxt = (id, val) => { const el = document.getElementById(id); if(el) el.innerText = val; };
            setTxt('txtSettingsTitle', text.settingsTitle); setTxt('txtSound', text.sound); setTxt('txtMusic', text.music); setTxt('txtLang', text.lang); setTxt('btnSettingsClose', text.close);
            setTxt('lblChooseChar', text.chooseChar); setTxt('btnStartGame', text.playBtn);
            setTxt('lblHintLeftRight', text.hintLR); setTxt('txtHintLeftRight', text.hintLRDesc); setTxt('lblHintUp', text.hintUp); setTxt('txtHintUp', text.hintUpDesc); setTxt('lblHintDown', text.hintDown); setTxt('txtHintDown', text.hintDownDesc);
            const currentMapData = mapsData.find(m => m.id === selectedMap); if(currentMapData && document.getElementById('btnMapSelect')) document.getElementById('btnMapSelect').innerHTML = text.mapLoc + `<span id="currentMapBtnText">${currentMapData.name}</span>`;
            updateCarousel();
        }

        let currentRunData = { coins: 0, diamonds: 0, distance: 0, jumps: 0, startMap: 'hutan' }; 

        const charactersData = [
            { id: 'tesya', name: 'Tesya', priceType: 'coin', price: 0, skin: '#ffe0bd', shirt: 'checker', bottom: '#e91e63', hair: '#111', style: 'skirt' },
            { id: 'winka', name: 'Winka', priceType: 'coin', price: 100, skin: '#ffceb4', shirt: '#ff69b4', bottom: '#ffa500', hair: '#111', style: 'pants', longHair: true },
