        function generateMapIconPNG(mapId) {
            const canvas = document.createElement('canvas'); canvas.width = 64; canvas.height = 64; const ctx = canvas.getContext('2d');
            if (mapId === 'kota') { ctx.fillStyle = '#111122'; ctx.fillRect(0,0,64,64); ctx.fillStyle = '#333'; ctx.fillRect(10, 20, 20, 44); ctx.fillStyle = '#444'; ctx.fillRect(35, 30, 20, 34); ctx.fillStyle = '#ffff99'; ctx.fillRect(15, 25, 4, 4); ctx.fillRect(40, 35, 4, 4); }
            else if (mapId === 'hutan') { ctx.fillStyle = '#87CEEB'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#4a3728'; ctx.fillRect(0,32,64,32); ctx.fillStyle = '#2a1a10'; ctx.fillRect(15, 30, 10, 20); ctx.fillStyle = '#0a220a'; ctx.beginPath(); ctx.arc(20, 20, 15, 0, Math.PI*2); ctx.fill(); ctx.fillStyle = '#2a1a10'; ctx.fillRect(40, 40, 8, 20); ctx.fillStyle = '#0a220a'; ctx.beginPath(); ctx.arc(44, 30, 12, 0, Math.PI*2); ctx.fill(); }
            else if (mapId === 'desa') { ctx.fillStyle = '#87CEFA'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#d2b48c'; ctx.fillRect(0,32,64,32); ctx.fillStyle = '#8b5a2b'; ctx.fillRect(20, 30, 24, 20); ctx.fillStyle = '#8b0000'; ctx.beginPath(); ctx.moveTo(10, 30); ctx.lineTo(32, 10); ctx.lineTo(54, 30); ctx.fill(); }
            else if (mapId === 'gurun') { ctx.fillStyle = '#FFCC66'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#EDC9AF'; ctx.fillRect(0,32,64,32); ctx.fillStyle = '#d2b48c'; ctx.beginPath(); ctx.arc(32, 40, 20, Math.PI, 0); ctx.fill(); ctx.fillStyle = '#228B22'; ctx.fillRect(15, 20, 4, 20); ctx.fillRect(10, 25, 10, 4); }
            else if (mapId === 'sungai') { ctx.fillStyle = '#6e7f80'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#3d2b1f'; ctx.fillRect(32,32,32,32); ctx.fillStyle = '#336699'; ctx.fillRect(0,32,32,32); ctx.fillStyle = '#2a1a10'; ctx.fillRect(40, 20, 8, 30); ctx.fillStyle = '#0a220a'; ctx.beginPath(); ctx.arc(44, 20, 12, 0, Math.PI*2); ctx.fill(); }
            else if (mapId === 'rel') { ctx.fillStyle = '#223344'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#444444'; ctx.fillRect(0,32,64,32); ctx.fillStyle = '#5c4033'; ctx.fillRect(20, 35, 24, 4); ctx.fillRect(15, 45, 34, 4); ctx.fillRect(10, 55, 44, 4); ctx.fillStyle = '#aaaaaa'; ctx.fillRect(25, 32, 2, 32); ctx.fillRect(37, 32, 2, 32); }
            else if (mapId === 'fantasi') { ctx.fillStyle = '#2b0057'; ctx.fillRect(0,0,64,64); ctx.fillStyle = '#00e5ff'; ctx.beginPath(); ctx.arc(32, 32, 15, 0, Math.PI*2); ctx.fill(); ctx.fillStyle = '#111'; ctx.fillRect(10, 40, 10, 24); ctx.beginPath(); ctx.moveTo(5, 40); ctx.lineTo(15, 25); ctx.lineTo(25, 40); ctx.fill(); ctx.fillRect(40, 30, 15, 34); ctx.beginPath(); ctx.moveTo(35, 30); ctx.lineTo(47.5, 15); ctx.lineTo(60, 30); ctx.fill(); }
            else if (mapId === 'lava') { ctx.fillStyle = '#3a0000'; ctx.fillRect(0,0,64,32); ctx.fillStyle = '#1a0505'; ctx.fillRect(0,32,64,32); ctx.fillStyle = '#ff3300'; ctx.beginPath(); ctx.moveTo(10, 64); ctx.lineTo(32, 20); ctx.lineTo(54, 64); ctx.fill(); ctx.fillStyle = '#ffaa00'; ctx.beginPath(); ctx.moveTo(25, 30); ctx.lineTo(32, 10); ctx.lineTo(39, 30); ctx.fill(); }
            return canvas.toDataURL('image/png');
        }

        function generateSidewalkTexture() {
            const canvas = document.createElement('canvas'); canvas.width = 256; canvas.height = 512; const ctx = canvas.getContext('2d');
            const colors = ['#CFCFCF', '#A8A8A8', '#7A7A7A']; ctx.fillStyle = '#A8A8A8'; ctx.fillRect(0, 0, 256, 512);
            for (let y = 0; y < 512; y += 32) { for (let x = 0; x < 256; x += 32) { ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)]; ctx.fillRect(x, y, 32, 32); ctx.strokeStyle = '#555555'; ctx.lineWidth = 1; ctx.strokeRect(x, y, 32, 32); } }
            ctx.globalAlpha = 0.4; ctx.fillStyle = '#8b5a2b'; for (let i = 0; i < 3000; i++) { ctx.beginPath(); ctx.arc(Math.random() * 256, Math.random() * 512, Math.random() * 4 + 1, 0, Math.PI * 2); ctx.fill(); }
            ctx.globalAlpha = 0.8; ctx.fillStyle = '#3cb371'; for (let i = 0; i < 1500; i++) { let x = (Math.random() > 0.5) ? (Math.random() * 15) : (256 - Math.random() * 15); ctx.beginPath(); ctx.arc(x, Math.random() * 512, Math.random() * 3 + 1, 0, Math.PI * 2); ctx.fill(); }
            const tex = new THREE.CanvasTexture(canvas); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(1, 10); return tex;
        }

        function generateGroundTexture(type) {
            const canvas = document.createElement('canvas'); canvas.width = 512; canvas.height = 512; const ctx = canvas.getContext('2d');
            if (type === 'kota') {
                ctx.fillStyle = '#444444'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 20000; i++) { let rand = Math.random(); ctx.fillStyle = rand < 0.3 ? '#333333' : (rand < 0.6 ? '#555555' : '#222222'); ctx.globalAlpha = Math.random() * 0.3 + 0.1; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 8 + 2, 0, Math.PI * 2); ctx.fill(); }
                ctx.globalAlpha = 0.5; ctx.fillStyle = '#3d2b1f'; ctx.fillRect(0, 0, 40, 512); ctx.fillRect(472, 0, 40, 512); 
            } else if (type === 'desa') {
                ctx.fillStyle = '#d2b48c'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 20000; i++) { let rand = Math.random(); ctx.fillStyle = rand < 0.4 ? '#5c4033' : (rand < 0.7 ? '#8b5a2b' : (rand < 0.85 ? '#3cb371' : '#e6c280')); ctx.globalAlpha = Math.random() * 0.4 + 0.1; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 12 + 3, 0, Math.PI * 2); ctx.fill(); }
            } else if (type === 'sungai') {
                ctx.fillStyle = '#3d2b1f'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 25000; i++) { let rand = Math.random(); ctx.fillStyle = rand < 0.5 ? '#2b1d14' : (rand < 0.8 ? '#4a3728' : '#2e3b22'); ctx.globalAlpha = Math.random() * 0.5 + 0.2; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 15 + 4, 0, Math.PI * 2); ctx.fill(); }
            } else if (type === 'rel') {
                ctx.fillStyle = '#444444'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 20000; i++) { ctx.fillStyle = Math.random() > 0.5 ? '#333333' : '#555555'; ctx.globalAlpha = Math.random() * 0.5 + 0.1; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 4 + 1, 0, Math.PI * 2); ctx.fill(); }
                ctx.globalAlpha = 1.0; ctx.fillStyle = '#5c4033'; const centers = [205, 256, 307];
                for(let y = 0; y < 512; y+= 30) { centers.forEach(c => ctx.fillRect(c - 22, y, 44, 8)); }
                ctx.fillStyle = '#aaaaaa'; centers.forEach(c => { ctx.fillRect(c - 16, 0, 4, 512); ctx.fillRect(c + 12, 0, 4, 512); });
            } else if (type === 'gurun') {
                let grd = ctx.createLinearGradient(0, 0, 0, 512); grd.addColorStop(0, "#e6c280"); grd.addColorStop(1, "#d2b48c"); ctx.fillStyle = grd; ctx.fillRect(0,0,512,512);
                ctx.fillStyle = '#b89465'; for(let i=0; i<40; i++) { ctx.beginPath(); ctx.arc(Math.random()*512, Math.random()*512, 10+Math.random()*25, 0, Math.PI*2); ctx.fill(); }
                for (let i = 0; i < 15000; i++) { ctx.fillStyle = Math.random() > 0.5 ? '#c2a278' : '#a88252'; ctx.globalAlpha = Math.random() * 0.4 + 0.1; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 2 + 1, 0, Math.PI * 2); ctx.fill(); }
                ctx.globalAlpha = 1.0;
            } else if (type === 'fantasi') {
                ctx.fillStyle = '#1a0033'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 5000; i++) { ctx.fillStyle = Math.random() > 0.5 ? '#aa00ff' : '#00e5ff'; ctx.globalAlpha = Math.random() * 0.5 + 0.1; ctx.beginPath(); ctx.arc(Math.random() * 512, Math.random() * 512, Math.random() * 4 + 1, 0, Math.PI * 2); ctx.fill(); }
                ctx.globalAlpha = 0.6; ctx.fillStyle = '#331144'; ctx.fillRect(170, 0, 172, 512); ctx.strokeStyle = '#00e5ff'; ctx.lineWidth = 2;
                for(let y = 0; y < 512; y+= 64) { ctx.strokeRect(175, y+5, 162, 54); } ctx.globalAlpha = 1.0;
            } else if (type === 'lava') {
                ctx.fillStyle = '#111111'; ctx.fillRect(0, 0, 512, 512); ctx.lineWidth = 3;
                for(let i=0; i<30; i++) {
                    ctx.strokeStyle = Math.random() > 0.5 ? '#ff3300' : '#ff0000'; ctx.beginPath(); let startX = Math.random() * 512, startY = Math.random() * 512; ctx.moveTo(startX, startY);
                    for(let j=0; j<5; j++) { startX += (Math.random() - 0.5) * 40; startY += (Math.random() - 0.5) * 40; ctx.lineTo(startX, startY); } ctx.stroke();
                }
            } else {
                ctx.fillStyle = '#2d4c1e'; ctx.fillRect(0, 0, 512, 512);
                for (let i = 0; i < 20000; i++) {
                    let x = Math.random() * 512; let y = Math.random() * 512; let rand = Math.random(); let dist = Math.abs(x / 512 - 0.5) * 2;
                    if (dist > 0.6) ctx.fillStyle = rand < 0.4 ? '#3cb371' : (rand < 0.7 ? '#228b22' : '#556b2f');
                    else ctx.fillStyle = rand < 0.3 ? '#8b5a2b' : (rand < 0.5 ? '#5c4033' : (rand < 0.7 ? '#2d4c1e' : '#3cb371'));
                    ctx.globalAlpha = Math.random() * 0.4 + 0.1; ctx.beginPath(); ctx.arc(x, y, Math.random() * 12 + 3, 0, Math.PI * 2); ctx.fill();
                }
            }
            if (!['kota', 'rel', 'gurun', 'fantasi', 'lava'].includes(type)) {
                ctx.globalAlpha = 1.0;
                for (let i = 0; i < 1000; i++) { ctx.fillStyle = Math.random() > 0.5 ? '#666666' : '#999999'; ctx.fillRect(Math.random() * 512, Math.random() * 512, 3, 3); }
                for (let i = 0; i < 400; i++) { ctx.fillStyle = Math.random() > 0.5 ? '#cc5500' : '#8b4500'; ctx.fillRect(Math.random() * 512, Math.random() * 512, 6, 3); }
            }
            const tex = new THREE.CanvasTexture(canvas); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(1, 10); return tex;
        }

        function createEmojiSprite(emoji) {
            const canvas = document.createElement('canvas'); canvas.width = 128; canvas.height = 128; const ctx = canvas.getContext('2d');
            ctx.font = '70px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.shadowColor = 'white'; ctx.shadowBlur = 15; ctx.fillText(emoji, 64, 64);
            return new THREE.Sprite(new THREE.SpriteMaterial({ map: new THREE.CanvasTexture(canvas), transparent: true }));
        }

        function generateCityTexture() {
            const canvas = document.createElement('canvas'); canvas.width = 128; canvas.height = 128; const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#222'; ctx.fillRect(0,0,128,128);
            for(let y=10; y<120; y+=25) { for(let x=10; x<120; x+=25) { if(Math.random() > 0.4) { ctx.fillStyle = Math.random() > 0.5 ? '#ffff99' : '#87CEFA'; ctx.fillRect(x, y, 15, 15); } } }
            return new THREE.CanvasTexture(canvas);
        }

        function createVariedTree(scale = 1, isDark = false) {
            const group = new THREE.Group();
            const trunkColors = [0x2a1a10, 0x3d2817, 0x4a3a2a, 0x222621];
            const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.5 * scale, 0.6 * scale, 4 * scale, 6), new THREE.MeshStandardMaterial({color: trunkColors[Math.floor(Math.random() * trunkColors.length)], roughness: 1}));
            trunk.position.y = 2 * scale; group.add(trunk);
            const leafMat = new THREE.MeshStandardMaterial({color: isDark ? 0x0a220a : (Math.random() > 0.5 ? 0x143306 : 0x1a4314), roughness: 0.9});
            const type = Math.floor(Math.random() * 3);
            if (type === 0) {
                const leaves = new THREE.Mesh(new THREE.DodecahedronGeometry(2.5 * scale, 1), leafMat); leaves.position.y = 5 * scale; leaves.scale.set(1, 0.9, 1); group.add(leaves);
            } else if (type === 1) {
                const center = new THREE.Mesh(new THREE.DodecahedronGeometry(2 * scale, 0), leafMat); center.position.y = 5 * scale;
                const l1 = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5 * scale, 0), leafMat); l1.position.set(1.2*scale, 4.5*scale, 0);
                const l2 = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5 * scale, 0), leafMat); l2.position.set(-1.2*scale, 4.5*scale, 0);
                const l3 = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5 * scale, 0), leafMat); l3.position.set(0, 4.5*scale, 1.2*scale);
                const l4 = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5 * scale, 0), leafMat); l4.position.set(0, 4.5*scale, -1.2*scale);
                group.add(center, l1, l2, l3, l4);
            } else {
                for(let i=0; i<2; i++) { const leaves = new THREE.Mesh(new THREE.ConeGeometry((2.5 - i*0.5)*scale, (5 - i)*scale, 7), leafMat); leaves.position.y = (4.5 + i*2)*scale; group.add(leaves); }
            }
            return group;
        }

        function create3DPlayer(charId, costumeId = 'default') {
            const charData = charactersData.find(c => c.id === charId); const group = new THREE.Group();
            let skinColor = charData.skin, shirtColor = charData.shirt, bottomColor = charData.bottom;
            let capeColor = 0x2b0057, auraColor = 0x00e5ff, fireColor1 = 0xff3300, fireColor2 = 0xffff00, lavaLineColor = '#ff3300';
            
            if (charId === 'penyihir') { if (costumeId === 'biru') { shirtColor = '#0055ff'; bottomColor = '#0055ff'; capeColor = 0x002288; auraColor = 0x00aaff; } else if (costumeId === 'emas') { shirtColor = '#ffd700'; bottomColor = '#ffd700'; capeColor = 0xb8860b; auraColor = 0xffea00; } } 
            else if (charId === 'api') { if (costumeId === 'biru') { skinColor = '#00e5ff'; fireColor1 = 0x00e5ff; fireColor2 = 0x0055ff; lavaLineColor = '#00e5ff'; } }

            const skinMat = new THREE.MeshStandardMaterial({ color: skinColor, roughness: 0.6 }), hairMat = new THREE.MeshStandardMaterial({ color: charData.hair, roughness: 0.8 });
            let bottomMat = new THREE.MeshStandardMaterial({ color: bottomColor, roughness: 0.7 }), shirtMat;
            
            if (charData.shirt === 'checker') {
                const canvas = document.createElement('canvas'); canvas.width = 64; canvas.height = 64; const ctx = canvas.getContext('2d');
                ctx.fillStyle = '#fff'; ctx.fillRect(0,0,64,64); ctx.fillStyle = '#222';
                for(let i=0; i<64; i+=16) { for(let j=0; j<64; j+=16) { if((i/16 + j/16) % 2 === 0) ctx.fillRect(i,j,16,16); } }
                const tex = new THREE.CanvasTexture(canvas); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(2, 2); shirtMat = new THREE.MeshStandardMaterial({ map: tex });
            } else { shirtMat = new THREE.MeshStandardMaterial({ color: shirtColor, roughness: 0.7 }); }

            let armSkinMat = skinMat, legMat = charData.style === 'skirt' ? skinMat : bottomMat, armorMat, goldMat, heroBlue, heroRed, heroGold;

            if (charId === 'ksatria') { armorMat = new THREE.MeshStandardMaterial({color: 0xcccccc, metalness: 0.8, roughness: 0.3}); goldMat = new THREE.MeshStandardMaterial({color: 0xffd700, metalness: 0.7, roughness: 0.2}); shirtMat = armorMat; armSkinMat = armorMat; legMat = armorMat; } 
            else if (charId === 'pahlawan') { heroBlue = new THREE.MeshStandardMaterial({color: 0x0000cd, roughness: 0.5}); heroRed = new THREE.MeshStandardMaterial({color: 0xdd0000, roughness: 0.5}); heroGold = new THREE.MeshStandardMaterial({color: 0xffd700, metalness: 0.8, roughness: 0.2}); shirtMat = heroBlue; legMat = heroBlue; } 
            else if (charId === 'api') {
                skinMat.emissive = new THREE.Color(skinColor); skinMat.emissiveIntensity = 0.5;
                const canvas = document.createElement('canvas'); canvas.width = 128; canvas.height = 128; const ctx = canvas.getContext('2d');
                ctx.fillStyle = '#111111'; ctx.fillRect(0,0,128,128); ctx.strokeStyle = lavaLineColor; ctx.lineWidth = 3;
                for(let i=0; i<8; i++) { ctx.beginPath(); ctx.moveTo(Math.random()*128, 0); ctx.lineTo(Math.random()*128, 64); ctx.lineTo(Math.random()*128, 128); ctx.stroke(); }
                const lavaTex = new THREE.CanvasTexture(canvas); lavaTex.wrapS = THREE.RepeatWrapping; lavaTex.wrapT = THREE.RepeatWrapping;
                let emissiveColor = costumeId === 'biru' ? 0x002244 : 0x330000;
                shirtMat = new THREE.MeshStandardMaterial({ map: lavaTex, emissive: emissiveColor }); legMat = new THREE.MeshStandardMaterial({ map: lavaTex, emissive: emissiveColor });
                armSkinMat = new THREE.MeshStandardMaterial({ color: skinColor, emissive: fireColor1, emissiveIntensity: 0.9 });
            }

            const headGroup = new THREE.Group(); headGroup.position.y = 2.5; headGroup.add(new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 16), skinMat));

            if (charId !== 'ksatria') {
                let eyeMatL = new THREE.MeshBasicMaterial({color: 0x111111}), eyeMatR = new THREE.MeshBasicMaterial({color: 0x111111});
                if (charId === 'api') { let eyeCol = costumeId === 'biru' ? 0xffffff : 0xffff00; eyeMatL = eyeMatR = new THREE.MeshBasicMaterial({color: eyeCol}); } 
                else if (charId === 'pahlawan' || charId === 'zombi') { eyeMatL = eyeMatR = new THREE.MeshBasicMaterial({color: 0xffffff}); }
                
                if (charId === 'robot') { const visor = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.12, 0.2), new THREE.MeshBasicMaterial({color: 0x00ffff})); visor.position.set(0, 0.05, 0.28); headGroup.add(visor); } 
                else {
                    const eyeGeo = new THREE.SphereGeometry(0.05, 8, 8);
                    if (charId === 'bajaklaut') {
                        const patch = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.02, 16), new THREE.MeshBasicMaterial({color: 0x111111})); patch.rotation.x = Math.PI / 2; patch.position.set(0.12, 0.05, 0.31); headGroup.add(patch);
                        const patchString = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.02, 0.3), new THREE.MeshBasicMaterial({color: 0x111111})); patchString.position.set(0, 0.05, 0.18); headGroup.add(patchString);
                    } else { const eyeL = new THREE.Mesh(eyeGeo, eyeMatL); eyeL.position.set(0.12, 0.05, 0.31); headGroup.add(eyeL); }
                    const eyeR = new THREE.Mesh(eyeGeo, eyeMatR); eyeR.position.set(-0.12, 0.05, 0.31); if (charId === 'zombi') eyeR.scale.set(1.5, 1.5, 1.5); headGroup.add(eyeR);
                }
                if (charId !== 'robot' && charId !== 'ninja') { const nose = new THREE.Mesh(new THREE.SphereGeometry(0.06, 8, 8), skinMat); nose.position.set(0, -0.06, 0.33); headGroup.add(nose); }
                if (charId !== 'robot' && charId !== 'ninja') { const mouth = new THREE.Mesh(new THREE.BoxGeometry(0.12, 0.02, 0.05), new THREE.MeshBasicMaterial({color: 0x331111})); mouth.position.set(0, -0.16, 0.31); if (charId === 'zombi') { mouth.rotation.z = 0.2; mouth.scale.set(1.5, 2, 1); } headGroup.add(mouth); }
                if (charId === 'ninja') { const ninjaMask = new THREE.Mesh(new THREE.CylinderGeometry(0.36, 0.35, 0.3, 16), new THREE.MeshStandardMaterial({color: 0x222222})); ninjaMask.position.set(0, -0.15, 0); headGroup.add(ninjaMask); }
            }
            group.add(headGroup);

            if (charId === 'pahlawan') { const mask = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.15, 0.35), heroRed); mask.position.set(0, 2.52, 0.18); group.add(mask); }

            if (charId !== 'ksatria' && charId !== 'api') {
                const hairBase = new THREE.Mesh(new THREE.SphereGeometry(0.38, 16, 16), hairMat); hairBase.position.y = 2.52; hairBase.position.z = -0.05; group.add(hairBase);
                if (charData.style === 'skirt' || charData.longHair) {
                    const ponytail = new THREE.Mesh(new THREE.ConeGeometry(0.18, 0.9, 8), hairMat); ponytail.position.set(0, 2.1, -0.38); ponytail.rotation.x = -0.3; group.add(ponytail);
                    const tie = new THREE.Mesh(new THREE.TorusGeometry(0.1, 0.05, 8, 16), new THREE.MeshStandardMaterial({color: 0xff0000})); tie.position.set(0, 2.5, -0.35); tie.rotation.x = Math.PI/2; group.add(tie);
                }
            } else if (charId === 'api') {
                const fireHairGroup = new THREE.Group();
                const flame1 = new THREE.Mesh(new THREE.ConeGeometry(0.3, 0.8, 8), new THREE.MeshStandardMaterial({color: fireColor1, emissive: fireColor1, emissiveIntensity: 0.8})); flame1.position.set(0, 0.2, -0.1);
                const flame2 = new THREE.Mesh(new THREE.ConeGeometry(0.2, 0.6, 8), new THREE.MeshStandardMaterial({color: fireColor2, emissive: fireColor2, emissiveIntensity: 0.8})); flame2.position.set(0, 0.1, 0.1);
                fireHairGroup.add(flame1, flame2); fireHairGroup.position.set(0, 2.7, 0); group.add(fireHairGroup);
            } else {
                const helmet = new THREE.Mesh(new THREE.CylinderGeometry(0.38, 0.4, 0.8, 16), armorMat); helmet.position.y = 2.5; group.add(helmet);
                const visor = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.12, 0.4), new THREE.MeshStandardMaterial({color: 0x111111})); visor.position.set(0, 2.55, 0.25); group.add(visor);
                const hornGeo = new THREE.ConeGeometry(0.12, 0.4, 8);
                const hornL = new THREE.Mesh(hornGeo, goldMat); hornL.position.set(0.4, 2.7, 0); hornL.rotation.z = -Math.PI/4;
                const hornR = new THREE.Mesh(hornGeo, goldMat); hornR.position.set(-0.4, 2.7, 0); hornR.rotation.z = Math.PI/4;
                group.add(hornL, hornR);
                const cape = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 1.6), new THREE.MeshStandardMaterial({color: 0xdd0000, side: THREE.DoubleSide})); cape.position.set(0, 1.3, -0.35); cape.rotation.x = 0.15; group.add(cape);
                const swordGroup = new THREE.Group();
                const handle = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.04, 0.3), new THREE.MeshStandardMaterial({color: 0x5c4033})); handle.position.y = 0.6;
                const guard = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.05, 0.05), goldMat); guard.position.y = 0.45;
                const blade = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.9, 0.02), armorMat); blade.position.y = -0.05;
                swordGroup.add(handle, guard, blade); swordGroup.position.set(0.1, 1.5, -0.42); swordGroup.rotation.z = Math.PI / 4; group.add(swordGroup);
            }

            const torso = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.35, 0.9, 16), shirtMat); torso.scale.z = 0.6; torso.position.y = 1.7; group.add(torso);

            if (charId === 'tesya') { const sash = new THREE.Mesh(new THREE.CylinderGeometry(0.36, 0.36, 0.15, 16), new THREE.MeshStandardMaterial({color: 0xdd0000})); sash.scale.z = 0.62; sash.position.y = 1.3; group.add(sash); }
            if (charId === 'pahlawan') {
                const logo = new THREE.Mesh(new THREE.CylinderGeometry(0.12, 0.12, 0.05, 16), heroGold); logo.rotation.x = Math.PI / 2; logo.position.set(0, 1.8, 0.20); group.add(logo);
                const belt = new THREE.Mesh(new THREE.CylinderGeometry(0.32, 0.32, 0.12, 16), heroGold); belt.position.y = 1.35; belt.scale.z = 0.62; group.add(belt);
                const cape = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 1.5), new THREE.MeshStandardMaterial({color: 0xdd0000, side: THREE.DoubleSide})); cape.position.set(0, 1.3, -0.25); cape.rotation.x = 0.35; group.add(cape);
            }

            if (charData.style === 'skirt') { const skirt = new THREE.Mesh(new THREE.CylinderGeometry(0.35, 0.45, 0.7, 16), bottomMat); skirt.scale.z = 0.7; skirt.position.y = 0.95; group.add(skirt); } 
            else { const pelvis = new THREE.Mesh(new THREE.CylinderGeometry(0.35, 0.35, 0.4, 16), charId === 'ksatria' ? armorMat : bottomMat); pelvis.scale.z = 0.6; pelvis.position.y = 1.1; group.add(pelvis); }

            function createLimb(rTop, rBot, len, mat) { const pivot = new THREE.Group(); const mesh = new THREE.Mesh(new THREE.CylinderGeometry(rTop, rBot, len, 12), mat); mesh.position.y = -len/2; pivot.add(mesh); return pivot; }

            const armL = createLimb(0.12, 0.1, 0.8, armSkinMat); armL.position.set(0.4, 2.0, 0);
            const armR = createLimb(0.12, 0.1, 0.8, armSkinMat); armR.position.set(-0.4, 2.0, 0);
            const sleeveL = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.13, 0.4, 12), shirtMat); sleeveL.position.y = -0.2; armL.add(sleeveL);
            const sleeveR = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.13, 0.4, 12), shirtMat); sleeveR.position.y = -0.2; armR.add(sleeveR);

            if (charId === 'pahlawan') { const gloveL = new THREE.Mesh(new THREE.CylinderGeometry(0.13, 0.11, 0.4, 12), heroRed); gloveL.position.y = -0.6; armL.add(gloveL); const gloveR = new THREE.Mesh(new THREE.CylinderGeometry(0.13, 0.11, 0.4, 12), heroRed); gloveR.position.y = -0.6; armR.add(gloveR); }
            if (charId === 'ksatria') { const pauldronGeo = new THREE.SphereGeometry(0.2, 16, 16, 0, Math.PI); const pauldronL = new THREE.Mesh(pauldronGeo, armorMat); pauldronL.rotation.z = Math.PI / 2; pauldronL.position.set(0, 0.1, 0); armL.add(pauldronL); const pauldronR = new THREE.Mesh(pauldronGeo, armorMat); pauldronR.rotation.z = -Math.PI / 2; pauldronR.position.set(0, 0.1, 0); armR.add(pauldronR); }
            if (charId === 'penyihir') {
                const hatGroup = new THREE.Group(); const brim = new THREE.Mesh(new THREE.CylinderGeometry(0.6, 0.6, 0.05, 16), shirtMat); brim.position.y = 0.2; const cone = new THREE.Mesh(new THREE.ConeGeometry(0.35, 1.2, 16), shirtMat); cone.position.y = 0.8;
                hatGroup.add(brim, cone); hatGroup.position.set(0, 2.65, 0); hatGroup.rotation.x = -0.15; group.add(hatGroup);
                const cape = new THREE.Mesh(new THREE.PlaneGeometry(0.9, 1.8), new THREE.MeshStandardMaterial({color: capeColor, side: THREE.DoubleSide})); cape.position.set(0, 1.1, -0.38); cape.rotation.x = 0.25; group.add(cape);
                const staffGroup = new THREE.Group(); const pole = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.04, 2.0, 8), new THREE.MeshStandardMaterial({color: 0x4a3219}));
                const crystal = new THREE.Mesh(new THREE.OctahedronGeometry(0.15), new THREE.MeshStandardMaterial({color: auraColor, emissive: auraColor, emissiveIntensity: 0.8, transparent: true, opacity: 0.9})); crystal.position.y = 1.0;
                const aura = new THREE.Mesh(new THREE.SphereGeometry(0.25), new THREE.MeshBasicMaterial({color: auraColor, transparent: true, opacity: 0.3})); aura.position.y = 1.0;
                staffGroup.add(pole, crystal, aura); staffGroup.position.set(-0.35, 1.6, -0.2); staffGroup.rotation.z = -Math.PI / 8; staffGroup.rotation.x = Math.PI / 6; group.add(staffGroup);
            }

            group.add(armL, armR); group.userData.armL = armL; group.userData.armR = armR;

            const legL = createLimb(0.14, 0.1, 0.9, legMat); legL.position.set(0.18, 0.9, 0);
            const legR = createLimb(0.14, 0.1, 0.9, legMat); legR.position.set(-0.18, 0.9, 0);
            
            let shoeColor = 0x222222; let shoeMat;
            if (charId === 'ksatria') shoeColor = 0x999999; else if (charId === 'pahlawan') shoeColor = 0xdd0000; else if (charId === 'api') shoeColor = skinColor;
            if (charId === 'api') { shoeMat = new THREE.MeshStandardMaterial({color: shoeColor, emissive: fireColor1, emissiveIntensity: 0.8}); } else { shoeMat = new THREE.MeshStandardMaterial({color: shoeColor}); }

            const shoeL = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.1, 0.25), shoeMat); shoeL.position.set(0, -0.9, 0.05); legL.add(shoeL);
            const shoeR = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.1, 0.25), shoeMat); shoeR.position.set(0, -0.9, 0.05); legR.add(shoeR);

            if (charId === 'pahlawan') { const bootL = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.12, 0.45, 12), heroRed); bootL.position.y = -0.65; legL.add(bootL); const bootR = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.12, 0.45, 12), heroRed); bootR.position.y = -0.65; legR.add(bootR); }

            group.add(legL, legR); group.userData.legL = legL; group.userData.legR = legR; group.rotation.y = Math.PI;

            if (charId === 'api' && costumeId === 'besar') { group.scale.set(1.2, 1.2, 1.2); group.position.y = 0.2; }
            return group;
        }

        function createEnemyModel() {
            const group = new THREE.Group();
            const head = new THREE.Mesh(new THREE.ConeGeometry(0.4, 0.7, 4), new THREE.MeshStandardMaterial({ color: 0x87CEEB, roughness: 0.9 }));
            head.position.y = 2.6; head.rotation.y = Math.PI / 4; 
            const eyeGeo = new THREE.SphereGeometry(0.06, 8, 8); const eyeMat = new THREE.MeshBasicMaterial({color: 0xff0000}); 
            const eyeL = new THREE.Mesh(eyeGeo, eyeMat); eyeL.position.set(0.12, 0.1, 0.28);
            const eyeR = new THREE.Mesh(eyeGeo, eyeMat); eyeR.position.set(-0.12, 0.1, 0.28);
            head.add(eyeL, eyeR); group.add(head);

            const shirtMat = new THREE.MeshStandardMaterial({ color: 0x00008b, roughness: 0.8 }); 
            const torso = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.35, 0.9, 16), shirtMat); torso.scale.z = 0.6; torso.position.y = 1.7; group.add(torso);

            function createLimb(rTop, rBot, len, mat) { const pivot = new THREE.Group(); const mesh = new THREE.Mesh(new THREE.CylinderGeometry(rTop, rBot, len, 12), mat); mesh.position.y = -len/2; pivot.add(mesh); return pivot; }

            const skinMat = new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.6 }), pantsMat = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.8 }); 
            const armL = createLimb(0.12, 0.1, 0.8, skinMat); armL.position.set(0.4, 2.0, 0); const armR = createLimb(0.12, 0.1, 0.8, skinMat); armR.position.set(-0.4, 2.0, 0);
            const sleeveL = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.13, 0.4, 12), shirtMat); sleeveL.position.y = -0.2; armL.add(sleeveL);
            const sleeveR = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.13, 0.4, 12), shirtMat); sleeveR.position.y = -0.2; armR.add(sleeveR);
            group.add(armL, armR); group.userData.armL = armL; group.userData.armR = armR;

            const legL = createLimb(0.14, 0.1, 0.9, pantsMat); legL.position.set(0.18, 0.9, 0); const legR = createLimb(0.14, 0.1, 0.9, pantsMat); legR.position.set(-0.18, 0.9, 0);
            group.add(legL, legR); group.userData.legL = legL; group.userData.legR = legR;
            group.rotation.y = Math.PI; return group;
        }

        let scene, camera, renderer, ambientLight, dirLight, playerLight; 
        let player, playerModel, shieldAura, ground, farGround, cityTexture; 
        let riverMesh = null, rainSystem = null, sandSystem = null, fantasyParticles = null; 
        let sidewalks = [], obstacles = [], coins = [], scenery = [], powerupItems = [], backgroundDecor = [], laneLines = [];
        let playerParticles = null, spawnTimer = 0;
        let gameSpeed = 0.3, baseGameSpeed = 0.3, score = 0, coinCount = 0;
        let isPlaying = false, isPaused = false, isCountingDown = false, isAnimating = false, controlsSetup = false;
        let selectedChar = 'tesya', selectedMap = 'hutan', activePowerup = null, powerupTimer = 0, hasShield = false, shieldTimer = 0;
        let enemyModel = null, bushHitCount = 0, enemyZOffset = 15; 
        let menuPreviewScene, menuPreviewCamera, menuPreviewRenderer, menuPreviewModels = [], menuPreviewReq, currentCharIdx = 0, currentMapIdx = 0, tempCostumePreview = null; 

        const LANE_WIDTH = 3, LANES = [-LANE_WIDTH, 0, LANE_WIDTH]; 
        let currentLane = 1, playerY = 1, velocityY = 0, gravity = -0.015; 
        let isJumping = false, isSliding = false, slideTimer = 0, speedMultiplier = 1.0; 
        let morningTransition = 0, sandstormTransition = 0, rainTransition = 0; 
        let reviveDiamondCost = 5, graceTimer = 0, blurTimer = 0, creepingTimer = 0, tutorialStep = 0, forestRainTarget = 0, forestNextWeatherChange = 1400;

        function simulateLoading() {
            let progress = 0; const bar = document.getElementById('loadingBar'); const text = document.getElementById('loadingText');
            const interval = setInterval(() => {
                progress += Math.floor(Math.random() * 15) + 5; 
                if (progress >= 100) {
                    progress = 100; clearInterval(interval); bar.style.width = '100%';
                    text.innerText = 'TAP LAYAR UNTUK MASUK'; text.style.animation = 'pulse 1s infinite'; text.style.color = '#fff'; text.style.fontSize = '18px'; text.style.cursor = 'pointer';
                    const startHandler = () => {
                        if (audioCtx.state === 'suspended') audioCtx.resume();
                        document.removeEventListener('click', startHandler); document.removeEventListener('touchstart', startHandler);
                        const loadingScreen = document.getElementById('loading');
                        loadingScreen.style.opacity = '0'; loadingScreen.style.transition = 'opacity 0.5s ease';
                        setTimeout(() => { loadingScreen.style.display = 'none'; }, 500);
                        playMenuBgm(); 
                        
                        const today = new Date().toDateString();
                        if (savedData.lastDailyGiftDate !== today && !hasAutoShownDaily) {
                            hasAutoShownDaily = true;
                            openDailyGiftModal();
                        }
                    };
                    document.addEventListener('click', startHandler); document.addEventListener('touchstart', startHandler);
                } else {
                    bar.style.width = progress + '%';
                    const messages = ["Memuat Aset 3D...", "Menyiapkan Lingkungan...", "Membangun Rintangan...", "Memanggil Musuh..."];
                    let msgIdx = Math.floor((progress / 100) * messages.length); if(msgIdx >= messages.length) msgIdx = messages.length - 1;
                    text.innerText = messages[msgIdx] + ` ${progress}%`;
                }
            }, 300); 
        }

        function init() {
            if (!scene) {
                scene = new THREE.Scene(); scene.background = new THREE.Color(0x111122); scene.fog = new THREE.Fog(0x111122, 20, 80);
                camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100); camera.position.set(0, 5, 12); camera.lookAt(0, 0, -10);
                renderer = new THREE.WebGLRenderer({ antialias: true }); renderer.setSize(window.innerWidth, window.innerHeight);
                document.getElementById('gameCanvas').innerHTML = ''; document.getElementById('gameCanvas').appendChild(renderer.domElement);
                ambientLight = new THREE.AmbientLight(0xffffff, 0.6); scene.add(ambientLight);
                dirLight = new THREE.DirectionalLight(0xffffff, 0.8); dirLight.position.set(10, 20, 10); scene.add(dirLight);
                window.removeEventListener('resize', onWindowResize); window.addEventListener('resize', onWindowResize);
            }
            setupMenuUI(); setupControls(); simulateLoading(); 
            if (!isAnimating) { isAnimating = true; animate(); }
        }

        function onWindowResize() { if (camera && renderer) { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); } }

        function initMenu3D() {
            if (menuPreviewRenderer) return; 
            const container = document.getElementById('menuCharCanvasContainer'); menuPreviewRenderer = new THREE.WebGLRenderer({ alpha: true, antialias: true }); menuPreviewRenderer.setSize(220, 170); container.appendChild(menuPreviewRenderer.domElement);
            menuPreviewScene = new THREE.Scene(); menuPreviewCamera = new THREE.PerspectiveCamera(50, 220/170, 0.1, 100); menuPreviewCamera.position.set(0, 1.8, 3.8); menuPreviewCamera.lookAt(0, 1.2, 0);
            menuPreviewScene.add(new THREE.AmbientLight(0xffffff, 0.8)); const dL = new THREE.DirectionalLight(0xffffff, 0.6); dL.position.set(2, 5, 5); menuPreviewScene.add(dL); animateMenuPreview();
        }

        function animateMenuPreview() {
            const isMenuVisible = document.getElementById('mainMenu').style.display !== 'none' || document.getElementById('shopMenu').style.display !== 'none';
            if (!isPlaying && isMenuVisible) {
                if (menuPreviewModels && menuPreviewModels.length > 0) {
                    const time = Date.now() * 0.002;
                    menuPreviewModels.forEach((m, idx) => {
                        m.rotation.y = Math.sin(time * 0.5) * 0.5; 
                        let charId = idx === 0 ? charactersData[currentCharIdx].id : charactersData[(currentCharIdx + 1) % charactersData.length].id;
                        m.position.y = (charId === 'penyihir' || charId === 'api') ? Math.sin(time) * 0.1 + (idx === 0 ? 0.1 : 0) : 0;
                    });
                }
                menuPreviewRenderer.render(menuPreviewScene, menuPreviewCamera);
            }
            menuPreviewReq = requestAnimationFrame(animateMenuPreview);
        }

        function updateCarousel() {
            const charData = charactersData[currentCharIdx]; const isUnlocked = savedData.unlockedChars.includes(charData.id);
            if (menuPreviewModels && menuPreviewModels.length > 0) { menuPreviewModels.forEach(m => menuPreviewScene.remove(m)); }
            menuPreviewModels = [];
            const nextIdx = (currentCharIdx + 1) % charactersData.length;
            let activeCostume = tempCostumePreview || (savedData.selectedCostumes[charData.id] || 'default');
            const currentModel = create3DPlayer(charData.id, activeCostume); const nextModel = create3DPlayer(charactersData[nextIdx].id, 'default'); 

            [currentModel, nextModel].forEach((m, index) => {
                m.rotation.y = 0; 
                if (m.userData.armL) { m.userData.armL.rotation.x = 0; m.userData.armL.rotation.z = Math.PI / 8; }
                if (m.userData.armR) { m.userData.armR.rotation.x = 0; m.userData.armR.rotation.z = -Math.PI / 8; }
                if (index === 1) { m.traverse((child) => { if (child.isMesh && child.material) { child.material = child.material.clone(); child.material.color.multiplyScalar(0.4); if(child.material.emissive) child.material.emissive.multiplyScalar(0.4); } }); }
            });

            currentModel.position.set(-0.5, 0, 0); currentModel.scale.set(1, 1, 1); nextModel.position.set(0.9, 0, -1); nextModel.scale.set(0.65, 0.65, 0.65);
            menuPreviewScene.add(currentModel, nextModel); menuPreviewModels.push(currentModel, nextModel);
            document.getElementById('carouselCharName').innerText = charData.name; document.getElementById('carouselCharDesc').innerHTML = charData.desc || '&nbsp;';

            const cosDiv = document.getElementById('costumeSelector'); cosDiv.innerHTML = '';
            if (isUnlocked && charData.costumes) {
                cosDiv.style.display = 'flex';
                charData.costumes.forEach(cos => {
                    const btnCos = document.createElement('button'); btnCos.className = 'costume-btn';
                    const isCosUnlocked = cos.type === 'free' || (savedData.unlockedCostumes[charData.id] && savedData.unlockedCostumes[charData.id].includes(cos.id));
                    const isSelected = activeCostume === cos.id;
                    btnCos.style.border = isSelected ? '2px solid #00e5ff' : '2px solid transparent'; btnCos.style.background = isSelected ? 'rgba(0,229,255,0.2)' : '#333'; btnCos.style.color = '#fff';
                    btnCos.innerText = isCosUnlocked ? cos.name : `${cos.name} (${cos.type === 'diamond' ? '💎' : '🪙'}${cos.price})`;
                    btnCos.onclick = () => {
                        playSound('select');
                        if (isCosUnlocked) { tempCostumePreview = cos.id; savedData.selectedCostumes[charData.id] = cos.id; saveGame(); updateCarousel(); } 
                        else {
                            showModal(`Beli kostum ${cos.name} seharga ${cos.price} ${cos.type === 'diamond' ? '💎' : 'Koin'}?`, true, () => {
                                if (cos.type === 'diamond' && savedData.totalDiamonds >= cos.price) { savedData.totalDiamonds -= cos.price; if(!savedData.unlockedCostumes[charData.id]) savedData.unlockedCostumes[charData.id] = []; savedData.unlockedCostumes[charData.id].push(cos.id); savedData.selectedCostumes[charData.id] = cos.id; tempCostumePreview = cos.id; saveGame(); setupMenuUI(); } 
                                else if (cos.type === 'coin' && savedData.totalCoins >= cos.price) { savedData.totalCoins -= cos.price; if(!savedData.unlockedCostumes[charData.id]) savedData.unlockedCostumes[charData.id] = []; savedData.unlockedCostumes[charData.id].push(cos.id); savedData.selectedCostumes[charData.id] = cos.id; tempCostumePreview = cos.id; saveGame(); setupMenuUI(); } 
                                else { showModal((cos.type === 'diamond' ? 'Diamond' : 'Koin') + " tidak cukup!", false); }
                            });
                        }
                    };
                    cosDiv.appendChild(btnCos);
                });
            } else { cosDiv.style.display = 'none'; }

            const previewBox = document.getElementById('charPreviewBox'); previewBox.className = 'char-preview-box';
            if (charData.priceType === 'diamond') previewBox.classList.add('premium');
            if (!isUnlocked) previewBox.classList.add('locked');
            document.getElementById('charLockOverlayCarousel').style.display = isUnlocked ? 'none' : 'block';

            const btn = document.getElementById('btnCharAction');
            if (isUnlocked) {
                if (selectedChar === charData.id) { btn.innerText = '✅ Dipilih'; btn.style.background = '#555'; btn.style.color = '#fff'; btn.style.transform = 'scale(0.95)'; previewBox.style.transform = 'scale(1.05)'; } 
                else { btn.innerText = 'Pilih Karakter'; btn.style.background = '#4CAF50'; btn.style.color = '#fff'; btn.style.transform = 'scale(1)'; previewBox.style.transform = 'scale(1)'; }
                btn.onclick = () => { selectedChar = charData.id; savedData.selectedCostumes[charData.id] = activeCostume; playSound('select'); updateCarousel(); };
            } else {
                previewBox.style.transform = 'scale(1)'; btn.style.transform = 'scale(1)';
                btn.innerHTML = charData.priceType === 'diamond' ? `Beli (💎 ${charData.price})` : `Beli (🪙 ${charData.price})`; btn.style.background = charData.priceType === 'diamond' ? '#00e5ff' : '#FFD700'; btn.style.color = '#000';
                btn.onclick = () => {
                    playSound('select');
                    if (charData.priceType === 'diamond') {
                        if (savedData.totalDiamonds >= charData.price) { showModal(`Beli karakter ${charData.name} seharga ${charData.price} 💎?`, true, () => { savedData.totalDiamonds -= charData.price; savedData.unlockedChars.push(charData.id); selectedChar = charData.id; saveGame(); setupMenuUI(); }); } 
                        else { showModal("Diamond tidak cukup! Mainkan game untuk mencari Diamond.", false); }
                    } else {
                        if (savedData.totalCoins >= charData.price) { showModal(`Beli karakter ${charData.name} seharga ${charData.price} 🪙?`, true, () => { savedData.totalCoins -= charData.price; savedData.unlockedChars.push(charData.id); selectedChar = charData.id; saveGame(); setupMenuUI(); }); } 
                        else { showModal("Koin tidak cukup!", false); }
                    }
                };
            }
        }

        function prevChar() { playSound('select'); tempCostumePreview = null; currentCharIdx--; if (currentCharIdx < 0) currentCharIdx = charactersData.length - 1; updateCarousel(); }
        function nextChar() { playSound('select'); tempCostumePreview = null; currentCharIdx++; if (currentCharIdx >= charactersData.length) currentCharIdx = 0; updateCarousel(); }

        function openMapMenu() { playSound('select'); document.getElementById('mainMenu').style.display = 'none'; document.getElementById('mapMenu').style.display = 'block'; renderMapGrid(); }
        function closeMapMenu() { playSound('select'); document.getElementById('mapMenu').style.display = 'none'; document.getElementById('mainMenu').style.display = 'block'; const currentMapData = mapsData.find(m => m.id === selectedMap); if(currentMapData) { document.getElementById('currentMapBtnText').innerText = currentMapData.name; } }
        function openShopMenu() { playSound('select'); document.getElementById('mainMenu').style.display = 'none'; document.getElementById('shopMenu').style.display = 'block'; updateMenuCoinsDisplay(); initMenu3D(); updateCarousel(); }
        function closeShopMenu() { playSound('select'); document.getElementById('shopMenu').style.display = 'none'; document.getElementById('mainMenu').style.display = 'block'; }

        function renderMapGrid() {
            const mapDiv = document.getElementById('mapSelectGrid'); mapDiv.innerHTML = ''; 
            mapsData.forEach((m) => {
                const mapIconPng = generateMapIconPNG(m.id); const isUnlocked = savedData.unlockedMaps.includes(m.id);
                const card = document.createElement('div'); card.className = `item-card ${selectedMap === m.id ? 'active' : ''}`;
                
                if (isUnlocked) {
                    card.innerHTML = `<img src="${mapIconPng}"><span class="item-name">${m.name}</span>`;
                    card.onclick = () => { playSound('select'); selectedMap = m.id; renderMapGrid(); };
                } else {
                    let priceHtml = '';
                    if (m.priceType === 'ad' || m.price === 'ad') { priceHtml = '<span class="price-tag">📺 Iklan</span>'; } 
                    else if (m.priceType === 'diamond') { priceHtml = `<span class="price-tag diamond" style="color:#00e5ff; border-color:#00e5ff;">💎 ${m.price}</span>`; } 
                    else { priceHtml = `<span class="price-tag">🪙 ${m.price}</span>`; }
                    card.innerHTML = `<div style="position:relative; display:inline-block;"><img src="${mapIconPng}" class="locked-char"><div style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); font-size:28px; text-shadow: 0 2px 4px #000;">🔒</div></div><span class="item-name" style="color:#aaa;">${m.name}</span>${priceHtml}`;
                    card.onclick = () => {
                        playSound('select');
                        if (m.priceType === 'ad' || m.price === 'ad') {
                            showModal(`Tonton iklan untuk membuka map ${m.name}?`, true, () => {
                                const alertBox = document.getElementById('customAlert'); document.getElementById('alertMessage').innerText = "📺 Sedang memutar iklan...\nMohon tunggu 3 detik...";
                                const btnOk = document.getElementById('btnAlertOk'); const btnCancel = document.getElementById('btnAlertCancel');
                                btnOk.style.display = 'none'; btnCancel.style.display = 'none'; alertBox.style.display = 'block';
                                setTimeout(() => { alertBox.style.display = 'none'; btnOk.style.display = 'block'; savedData.unlockedMaps.push(m.id); selectedMap = m.id; saveGame(); renderMapGrid(); showModal("✅ Iklan selesai! Map berhasil dibuka.", false); }, 3000);
                            });
                        } else if (m.priceType === 'diamond') {
                            if (savedData.totalDiamonds >= m.price) { showModal(`Beli map ${m.name} seharga ${m.price} 💎?`, true, () => { savedData.totalDiamonds -= m.price; savedData.unlockedMaps.push(m.id); selectedMap = m.id; saveGame(); updateMenuCoinsDisplay(); renderMapGrid(); }); } 
                            else { showModal("Diamond tidak cukup untuk membeli map ini!", false); }
                        } else {
                            if (savedData.totalCoins >= m.price) { showModal(`Beli map ${m.name} seharga ${m.price} koin?`, true, () => { savedData.totalCoins -= m.price; savedData.unlockedMaps.push(m.id); selectedMap = m.id; saveGame(); updateMenuCoinsDisplay(); renderMapGrid(); }); } 
                            else { showModal("Koin tidak cukup untuk membeli map ini!", false); }
                        }
                    };
                }
                mapDiv.appendChild(card);
            });
        }

        function setupMenuUI() {
            currentCharIdx = charactersData.findIndex(c => c.id === selectedChar); if (currentCharIdx === -1) currentCharIdx = 0; tempCostumePreview = null;
            currentMapIdx = mapsData.findIndex(m => m.id === selectedMap); if (currentMapIdx === -1) currentMapIdx = 0;
            updateMenuCoinsDisplay();
            initMenu3D(); updateCarousel();
            const currentMapData = mapsData.find(m => m.id === selectedMap); if(currentMapData) document.getElementById('currentMapBtnText').innerText = currentMapData.name;
        }

        function buildWorld() {
            obstacles.forEach(o => scene.remove(o)); obstacles = []; coins.forEach(c => scene.remove(c)); coins = []; scenery.forEach(s => scene.remove(s)); scenery = []; powerupItems.forEach(p => scene.remove(p)); powerupItems = []; backgroundDecor.forEach(bd => scene.remove(bd)); backgroundDecor = []; sidewalks.forEach(s => scene.remove(s)); sidewalks = []; 
            if(ground) scene.remove(ground); if(farGround) scene.remove(farGround); if(player) scene.remove(player); if(riverMesh) { scene.remove(riverMesh); riverMesh = null; } if(rainSystem) { scene.remove(rainSystem); rainSystem = null; } if(sandSystem) { scene.remove(sandSystem); sandSystem = null; } if(fantasyParticles) { scene.remove(fantasyParticles); fantasyParticles = null; } if(playerParticles) { scene.remove(playerParticles); playerParticles = null; }

            const mapTheme = mapsData.find(m => m.id === selectedMap); scene.background = new THREE.Color(mapTheme.bg);
            
            if (['sungai', 'desa', 'hutan'].includes(selectedMap)) {
                const rainGeo = new THREE.BufferGeometry(); const rainCount = 1500; const positions = new Float32Array(rainCount * 3);
                for(let i=0; i<rainCount*3; i+=3) { positions[i] = (Math.random() - 0.5) * 60; positions[i+1] = Math.random() * 40; positions[i+2] = (Math.random() - 0.5) * 60 - 10; }
                rainGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
                rainSystem = new THREE.Points(rainGeo, new THREE.PointsMaterial({color: 0xffffff, size: 0.2, transparent: true, opacity: selectedMap === 'sungai' ? 0.7 : 0})); scene.add(rainSystem);
            }

            if (selectedMap === 'sungai') {
                scene.fog = new THREE.Fog(mapTheme.fog, 20, 80); ambientLight.intensity = 0.4; dirLight.intensity = 0.5;
                riverMesh = new THREE.Mesh(new THREE.PlaneGeometry(25, 400), new THREE.MeshStandardMaterial({color: 0x1ca3ec, roughness: 0.1, metalness: 0.2})); riverMesh.rotation.x = -Math.PI / 2; riverMesh.position.set(19.5, -0.05, -50); scene.add(riverMesh);
            } else if (selectedMap === 'kota' || selectedMap === 'rel') {
                scene.fog = new THREE.FogExp2(mapTheme.fog, 0.02); ambientLight.intensity = 0.5; dirLight.intensity = 0.8;
            } else if (selectedMap === 'gurun') {
                scene.fog = new THREE.FogExp2(mapTheme.fog, 0.025); ambientLight.intensity = 0.7; dirLight.intensity = 0.9;
                const sandGeo = new THREE.BufferGeometry(); const sandCount = 2000; const positions = new Float32Array(sandCount * 3);
                for(let i=0; i<sandCount*3; i+=3) { positions[i] = (Math.random() - 0.5) * 80; positions[i+1] = Math.random() * 15; positions[i+2] = (Math.random() - 0.5) * 80 - 20; }
                sandGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
                sandSystem = new THREE.Points(sandGeo, new THREE.PointsMaterial({color: 0xd2b48c, size: 0.15, transparent: true, opacity: 0.7})); scene.add(sandSystem);
            } else if (selectedMap === 'fantasi') {
                scene.fog = new THREE.FogExp2(mapTheme.fog, 0.025); ambientLight.intensity = 0.4; dirLight.intensity = 0.6; dirLight.color.setHex(0xaa00ff); 
                const dustGeo = new THREE.BufferGeometry(); const dustCount = 2500; const positions = new Float32Array(dustCount * 3);
                for(let i=0; i<dustCount*3; i+=3) { positions[i] = (Math.random() - 0.5) * 80; positions[i+1] = Math.random() * 40; positions[i+2] = (Math.random() - 0.5) * 80 - 20; }
                dustGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
                fantasyParticles = new THREE.Points(dustGeo, new THREE.PointsMaterial({color: 0x00e5ff, size: 0.2, transparent: true, opacity: 0.6, blending: THREE.AdditiveBlending})); scene.add(fantasyParticles);
            } else if (selectedMap === 'lava') {
                scene.fog = new THREE.FogExp2(mapTheme.fog, 0.03); ambientLight.intensity = 0.3; dirLight.intensity = 0.5; dirLight.color.setHex(0xffaa00);
                const emberGeo = new THREE.BufferGeometry(); const emberCount = 800; const positions = new Float32Array(emberCount * 3);
                for(let i=0; i<emberCount*3; i+=3) { positions[i] = (Math.random() - 0.5) * 80; positions[i+1] = Math.random() * 40; positions[i+2] = (Math.random() - 0.5) * 80 - 20; }
                emberGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
                fantasyParticles = new THREE.Points(emberGeo, new THREE.PointsMaterial({color: 0xff5500, size: 0.3, transparent: true, opacity: 0.8, blending: THREE.AdditiveBlending})); scene.add(fantasyParticles);
            } else { scene.fog = new THREE.Fog(mapTheme.fog, 20, 80); ambientLight.intensity = 0.6; dirLight.intensity = 0.8; }
            
            if (playerLight) { scene.remove(playerLight); playerLight = null; }

            let groundMatParams = { color: mapTheme.ground };
            if (['hutan', 'desa', 'sungai', 'kota', 'rel', 'gurun', 'fantasi', 'lava'].includes(selectedMap)) { groundMatParams.map = generateGroundTexture(selectedMap); groundMatParams.color = 0xffffff; }
            ground = new THREE.Mesh(new THREE.PlaneGeometry(30, 200), new THREE.MeshStandardMaterial(groundMatParams)); ground.rotation.x = -Math.PI / 2; ground.position.z = -50;
            if (selectedMap === 'sungai') ground.position.x = -8; 
            scene.add(ground);

            let farColor = mapTheme.ground;
            if (selectedMap === 'desa') farColor = 0x3cb371; if (selectedMap === 'hutan') farColor = 0x1e3315; if (selectedMap === 'sungai') farColor = 0x3d2b1f; if (selectedMap === 'kota' || selectedMap === 'rel') farColor = 0x111122; if (selectedMap === 'gurun') farColor = 0xEDC9AF; if (selectedMap === 'fantasi') farColor = 0x1a0033; if (selectedMap === 'lava') farColor = 0x1a0505;
            farGround = new THREE.Mesh(new THREE.PlaneGeometry(600, 600), new THREE.MeshStandardMaterial({ color: farColor })); farGround.rotation.x = -Math.PI / 2; farGround.position.y = -0.1; farGround.position.z = -200; scene.add(farGround);

            laneLines.forEach(l => scene.remove(l)); laneLines = [];
            for(let i=-1; i<=1; i++) {
                const lineMat = new THREE.MeshBasicMaterial({ color: selectedMap === 'kota' ? 0xFFD700 : (selectedMap === 'fantasi' ? 0x00e5ff : (selectedMap === 'lava' ? 0xff3300 : (['hutan', 'desa', 'sungai', 'gurun'].includes(selectedMap) ? 0x2a1608 : 0xffffff))), opacity: selectedMap === 'kota' ? 0.7 : (selectedMap === 'fantasi' ? 0.4 : (selectedMap === 'lava' ? 0.6 : (['hutan', 'desa', 'sungai', 'gurun'].includes(selectedMap) ? 0.2 : (selectedMap === 'rel' ? 0 : 0.3)))), transparent: true });
                const line = new THREE.Mesh(new THREE.PlaneGeometry(0.2, 200), lineMat); line.rotation.x = -Math.PI/2; line.position.set(i * LANE_WIDTH, 0.01, -50); scene.add(line); laneLines.push(line);
            }

            player = new THREE.Group();
            const hitbox = new THREE.Mesh(new THREE.BoxGeometry(1.5, 2, 1.5), new THREE.MeshBasicMaterial({ visible: false })); hitbox.position.y = 1; player.add(hitbox);
            playerModel = create3DPlayer(selectedChar, savedData.selectedCostumes[selectedChar] || 'default'); player.add(playerModel);
            shieldAura = new THREE.Mesh(new THREE.SphereGeometry(1.8, 16, 16), new THREE.MeshBasicMaterial({color: 0x00ffff, wireframe: true, transparent: true, opacity: 0.6})); shieldAura.position.y = 1.2; shieldAura.visible = false; player.add(shieldAura);
            player.position.set(LANES[currentLane], 0, 0); scene.add(player);

            if (enemyModel) scene.remove(enemyModel); enemyModel = createEnemyModel(); enemyModel.position.set(LANES[currentLane], 0, 15); scene.add(enemyModel);

            playerParticles = new THREE.Group(); scene.add(playerParticles);

            if (['hutan', 'sungai', 'fantasi'].includes(selectedMap)) {
                for(let i = 0; i < 16; i++) { 
                    let mountain;
                    if (selectedMap === 'sungai' && i % 2 === 0) {
                        mountain = new THREE.Mesh(new THREE.SphereGeometry(15 + Math.random()*10, 16, 16), new THREE.MeshStandardMaterial({color: 0x2e3b22, roughness: 0.9})); mountain.position.set(30 + Math.random()*20, -3, -40 - Math.random()*100);
                    } else if (selectedMap === 'fantasi') {
                        mountain = new THREE.Mesh(new THREE.ConeGeometry(20 + Math.random()*15, 60 + Math.random()*50, 6), new THREE.MeshStandardMaterial({color: 0x110022, roughness: 0.8, emissive: 0x2a0044, emissiveIntensity: 0.4}));
                        const side = Math.random() > 0.5 ? 1 : -1; mountain.position.set(side * (50 + Math.random()*30), -10, -60 - Math.random()*80);
                        if (Math.random() > 0.6) {
                            const tower = new THREE.Mesh(new THREE.BoxGeometry(10, 40, 10), new THREE.MeshStandardMaterial({color: 0x111111})); tower.position.set(side * (30 + Math.random()*20), 10, -80 - Math.random()*60);
                            const windowGlow = new THREE.Mesh(new THREE.PlaneGeometry(2, 4), new THREE.MeshBasicMaterial({color: 0x00e5ff})); windowGlow.position.set(side === 1 ? -5.1 : 5.1, 15, 0); windowGlow.rotation.y = side === 1 ? -Math.PI/2 : Math.PI/2;
                            tower.add(windowGlow); scene.add(tower); backgroundDecor.push(tower);
                        }
                    } else {
                        const mountColors = [0x142b14, 0x1e3b1e, 0x173017];
                        mountain = new THREE.Mesh(new THREE.ConeGeometry(30 + Math.random()*20, 50 + Math.random()*40, 8), new THREE.MeshStandardMaterial({color: mountColors[Math.floor(Math.random() * mountColors.length)], roughness: 1}));
                        const side = selectedMap === 'sungai' ? -1 : (Math.random() > 0.5 ? 1 : -1); mountain.position.set(side * (50 + Math.random()*30), -5, -60 - Math.random()*80);
                        if (selectedMap === 'hutan' && Math.random() > 0.3) { const giantTree = createVariedTree(3 + Math.random()*2, true); giantTree.position.set(side * (25 + Math.random()*15), -2, -40 - Math.random()*40); scene.add(giantTree); backgroundDecor.push(giantTree); }
                    }
                    scene.add(mountain); backgroundDecor.push(mountain);
                }
            } else if (selectedMap === 'desa') {
                for(let i = 0; i < 30; i++) { const treeGroup = createVariedTree(1.5 + Math.random(), false); const side = Math.random() > 0.5 ? 1 : -1; treeGroup.position.set(side * (30 + Math.random()*40), 0, -60 - Math.random()*120); scene.add(treeGroup); backgroundDecor.push(treeGroup); }
            } else if (selectedMap === 'kota') {
                for(let i = 0; i < 20; i++) { const bgBuilding = new THREE.Mesh(new THREE.BoxGeometry(10 + Math.random()*10, 30 + Math.random()*40, 10), new THREE.MeshStandardMaterial({color: 0x111111})); const side = Math.random() > 0.5 ? 1 : -1; bgBuilding.position.set(side * (30 + Math.random()*30), 15, -60 - Math.random()*120); scene.add(bgBuilding); backgroundDecor.push(bgBuilding); }
                const sidewalkTex = generateSidewalkTexture(); const sidewalkMat = new THREE.MeshStandardMaterial({ map: sidewalkTex, roughness: 0.9 });
                const curbL = new THREE.Mesh(new THREE.BoxGeometry(4, 0.4, 200), sidewalkMat); curbL.position.set(-8.5, 0.2, -50); scene.add(curbL); sidewalks.push(curbL);
                const curbR = new THREE.Mesh(new THREE.BoxGeometry(4, 0.4, 200), sidewalkMat); curbR.position.set(8.5, 0.2, -50); scene.add(curbR); sidewalks.push(curbR);
            } else if (selectedMap === 'rel') {
                for(let i = 0; i < 15; i++) { const hill = new THREE.Mesh(new THREE.SphereGeometry(15 + Math.random()*15, 8, 8), new THREE.MeshStandardMaterial({color: 0x1a242f})); const side = Math.random() > 0.5 ? 1 : -1; hill.position.set(side * (30 + Math.random()*30), -5, -60 - Math.random()*120); scene.add(hill); backgroundDecor.push(hill); }
            } else if (selectedMap === 'gurun') {
                for(let i = 0; i < 12; i++) { const dune = new THREE.Mesh(new THREE.SphereGeometry(20 + Math.random()*25, 16, 16), new THREE.MeshStandardMaterial({color: 0xd2b48c, roughness: 1})); const side = Math.random() > 0.5 ? 1 : -1; dune.position.set(side * (40 + Math.random()*50), -10, -80 - Math.random()*100); scene.add(dune); backgroundDecor.push(dune); }
            } else if (selectedMap === 'lava') {
                for(let i = 0; i < 20; i++) {
                    const volcano = new THREE.Mesh(new THREE.ConeGeometry(20 + Math.random()*15, 40 + Math.random()*30, 8), new THREE.MeshStandardMaterial({color: 0x110000, roughness: 1}));
                    const side = Math.random() > 0.5 ? 1 : -1; volcano.position.set(side * (40 + Math.random()*30), -10, -60 - Math.random()*100);
                    const lavaFlow = new THREE.Mesh(new THREE.ConeGeometry(10, 41, 8), new THREE.MeshBasicMaterial({color: 0xff3300})); lavaFlow.position.set(side*0.5, 0, 0);
                    volcano.add(lavaFlow); scene.add(volcano); backgroundDecor.push(volcano);
                }
            }
            for (let z = -20; z >= -150; z -= 20) spawnScenery(z);
            if(!cityTexture) cityTexture = generateCityTexture();
        }

        function spawnScenery(zPos) {
            [-1, 1].forEach(side => {
                if (selectedMap === 'sungai') {
                    if (side === 1) { 
                        if (Math.random() > 0.5) { const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5), new THREE.MeshStandardMaterial({color: 0x445555, roughness: 0.2})); rock.position.set(5 + Math.random()*2, 0, zPos); scene.add(rock); scenery.push(rock); }
                        if (Math.random() > 0.6) { const tree = createVariedTree(1 + Math.random()*0.3, true); tree.position.set(35 + Math.random()*8, 0, zPos); scene.add(tree); scenery.push(tree); } return; 
                    } else { 
                        if (Math.random() > 0.3) { const tree = createVariedTree(1 + Math.random()*0.3, true); tree.position.set(-6 - Math.random()*4, 0, zPos); scene.add(tree); scenery.push(tree); } return;
                    }
                } else if (selectedMap === 'kota') {
                    if (Math.random() > 0.1) {
                        const h = 15 + Math.random() * 30; const w = 6 + Math.random() * 4;
                        const building = new THREE.Mesh(new THREE.BoxGeometry(w, h, 6), new THREE.MeshStandardMaterial({ map: cityTexture, color: Math.random() * 0xaaaaaa })); building.position.set(side * (10.5 + w/2), h/2, zPos); scene.add(building); scenery.push(building);
                        if (Math.random() > 0.6) {
                            const pole = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 8), new THREE.MeshStandardMaterial({color: 0x333333})); pole.position.set(side * 7.5, 4, zPos + 2);
                            const arm = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 1.5), new THREE.MeshStandardMaterial({color: 0x333333})); arm.rotation.z = Math.PI / 2; arm.position.set(side * 6.75, 8, zPos + 2);
                            const light = new THREE.Mesh(new THREE.SphereGeometry(0.3), new THREE.MeshBasicMaterial({color: 0xffffaa})); light.position.set(side * 6.0, 8, zPos + 2); 
                            scene.add(pole, arm, light); scenery.push(pole, arm, light);
                        }
                    } return; 
                } else if (selectedMap === 'rel') {
                    if (score >= 1500 && score <= 1800) {
                        const platformGroup = new THREE.Group();
                        const platform = new THREE.Mesh(new THREE.BoxGeometry(12, 1.5, 20), new THREE.MeshStandardMaterial({color: 0x999999, roughness: 0.9})); platform.position.set(side * 11, 0.75, 0);
                        const pillarMat = new THREE.MeshStandardMaterial({color: 0x444444});
                        const p1 = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 6, 8), pillarMat); p1.position.set(side * 7.5, 3, -6); const p2 = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 6, 8), pillarMat); p2.position.set(side * 7.5, 3, 6);
                        const roof = new THREE.Mesh(new THREE.BoxGeometry(14, 0.5, 20), new THREE.MeshStandardMaterial({color: 0x222222})); roof.position.set(side * 12, 6, 0); roof.rotation.z = side === 1 ? 0.1 : -0.1; 
                        platformGroup.add(platform, p1, p2, roof); platformGroup.position.set(0, 0, zPos); scene.add(platformGroup); scenery.push(platformGroup); return;
                    }
                    if (Math.random() > 0.7) {
                        const pole = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 10), new THREE.MeshStandardMaterial({color: 0x3d2616})); pole.position.set(side * 6, 5, zPos);
                        const lightBox = new THREE.Mesh(new THREE.BoxGeometry(0.6, 1.2, 0.6), new THREE.MeshStandardMaterial({color: 0x222222})); lightBox.position.set(side * 5.6, 8, zPos);
                        const bulbColor = Math.random() > 0.5 ? 0xff0000 : 0x00ff00; const bulb = new THREE.Mesh(new THREE.SphereGeometry(0.3), new THREE.MeshBasicMaterial({color: bulbColor, emissive: bulbColor, emissiveIntensity: 0.5})); bulb.position.set(side * 5.3, 8, zPos);
                        const group = new THREE.Group(); group.add(pole, lightBox, bulb); scene.add(group); scenery.push(group);
                    } return;
                } else if (selectedMap === 'gurun') {
                    if (Math.random() > 0.4) {
                        const cactusMat = new THREE.MeshStandardMaterial({color: 0x2e8b57}); const cactus = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 5, 8), cactusMat); cactus.position.set(side * (5 + Math.random()*5), 2.5, zPos);
                        if (Math.random() > 0.5) { const arm1 = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, 1.5, 8), cactusMat); arm1.rotation.z = Math.PI/2; arm1.position.set(0.8, 0, 0); const arm1Up = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, 1.5, 8), cactusMat); arm1Up.position.set(1.4, 0.6, 0); cactus.add(arm1, arm1Up); }
                        scene.add(cactus); scenery.push(cactus);
                    } return;
                } else if (selectedMap === 'fantasi') {
                    if (Math.random() > 0.4) {
                        const group = new THREE.Group();
                        if (Math.random() > 0.5) {
                            const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.5, 4, 8), new THREE.MeshStandardMaterial({color: 0x1a0033})); trunk.position.y = 2;
                            const leaves = new THREE.Mesh(new THREE.DodecahedronGeometry(2), new THREE.MeshStandardMaterial({color: 0xaa00ff, emissive: 0x4a0088, transparent: true, opacity: 0.8})); leaves.position.y = 4; group.add(trunk, leaves);
                        } else {
                            const crystalColor = Math.random() > 0.5 ? 0x00e5ff : 0xff00ff; const crystal = new THREE.Mesh(new THREE.OctahedronGeometry(1.5 + Math.random()), new THREE.MeshStandardMaterial({color: crystalColor, emissive: crystalColor, emissiveIntensity: 0.6, transparent: true, opacity: 0.8})); crystal.position.y = 1; crystal.scale.set(0.5, 2, 0.5); group.add(crystal);
                        }
                        group.position.set(side * (6 + Math.random()*5), 0, zPos); scene.add(group); scenery.push(group);
                    } return;
                } else if (selectedMap === 'lava') {
                    if (Math.random() > 0.3) {
                        const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(2 + Math.random()), new THREE.MeshStandardMaterial({color: 0x1a0505, roughness: 0.9})); rock.position.set(side * (8 + Math.random()*5), 0, zPos); scene.add(rock); scenery.push(rock);
                    } return;
                }

                if(Math.random() < 0.3) return; 
                let mesh;
                if(selectedMap === 'hutan') { mesh = createVariedTree(1 + Math.random()*0.5, true); mesh.position.set(side * (LANE_WIDTH * 2), 0, zPos); } 
                else if(selectedMap === 'desa') {
                    mesh = new THREE.Group();
                    const walls = new THREE.Mesh(new THREE.BoxGeometry(4, 3, 4), new THREE.MeshStandardMaterial({color: 0x8b5a2b})); walls.position.y = 1.5;
                    const roof = new THREE.Mesh(new THREE.ConeGeometry(3.5, 2.5, 4), new THREE.MeshStandardMaterial({color: 0x8b0000})); roof.position.y = 4.25; roof.rotation.y = Math.PI / 4; 
                    const door = new THREE.Mesh(new THREE.PlaneGeometry(1, 1.8), new THREE.MeshStandardMaterial({color: 0x3d2616})); door.position.set(side * -2.01, 0.9, 0); door.rotation.y = side === 1 ? -Math.PI/2 : Math.PI/2;
                    const winMat = new THREE.MeshStandardMaterial({color: 0x87CEFA}); 
                    const window1 = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.8), winMat); window1.position.set(side * -2.01, 1.8, 1.2); window1.rotation.y = side === 1 ? -Math.PI/2 : Math.PI/2;
                    const window2 = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.8), winMat); window2.position.set(side * -2.01, 1.8, -1.2); window2.rotation.y = side === 1 ? -Math.PI/2 : Math.PI/2;
                    mesh.add(walls, roof, door, window1, window2);
                    for(let t = 0; t < 4; t++) { const tTree = createVariedTree(0.7 + Math.random()*0.3, false); tTree.position.set(side * (2 + Math.random() * 4), 0, (Math.random() - 0.5) * 12); mesh.add(tTree); }
                    mesh.position.set(side * (LANE_WIDTH * 2 + 3), 0, zPos);
                } else { mesh = new THREE.Mesh(new THREE.DodecahedronGeometry(2), new THREE.MeshStandardMaterial({color: selectedMap === 'gurun' ? 0xa0522d : 0xaaaaaa})); mesh.position.set(side * (LANE_WIDTH * 2), 1, zPos); }
                scene.add(mesh); scenery.push(mesh);
            });
        }

        function spawnObstacle() {
            const xPos = LANES[Math.floor(Math.random() * 3)], zPos = -100; 
            let maxType = 3;
            if (selectedMap === 'kota' || selectedMap === 'fantasi') maxType = 7;
            else if (selectedMap === 'rel' || selectedMap === 'gurun') maxType = 6; 
            else if (selectedMap === 'desa' || selectedMap === 'sungai' || selectedMap === 'lava') maxType = 5; 
            else if (selectedMap === 'hutan') maxType = 4;
            
            let type = Math.floor(Math.random() * maxType); 
            if (selectedMap === 'rel' && score >= 1500 && score <= 1800 && Math.random() > 0.4) type = 5;

            const obsGroup = new THREE.Group();
            
            if (selectedMap === 'lava') {
                if (type === 0) { 
                    const pool = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 0.1, 4), new THREE.MeshBasicMaterial({color: 0xff3300})); pool.position.y = 0.05;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 1, 3.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.5;
                    obsGroup.add(pool, hitbox); obsGroup.userData.isInstaDeath = true;
                } else if (type === 1) { 
                    const eruption = new THREE.Mesh(new THREE.CylinderGeometry(0.8, 0.8, 6, 8), new THREE.MeshBasicMaterial({color: 0xff5500})); eruption.position.y = -3; 
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(1.5, 6, 1.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = -3;
                    const warnMark = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), new THREE.MeshBasicMaterial({color: 0xff0000})); warnMark.rotation.x = -Math.PI/2; warnMark.position.y = 0.02;
                    obsGroup.add(eruption, hitbox, warnMark); obsGroup.userData = { isEruption: true, isInstaDeath: true };
                } else if (type === 2) { 
                    const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(1.2), new THREE.MeshStandardMaterial({color: 0x221111, roughness: 1})); rock.position.y = 15; 
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 2, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 15;
                    const shadow = new THREE.Mesh(new THREE.CircleGeometry(1.5, 16), new THREE.MeshBasicMaterial({color: 0x000000, transparent: true, opacity: 0.5})); shadow.rotation.x = -Math.PI/2; shadow.position.y = 0.05;
                    obsGroup.add(rock, hitbox, shadow); obsGroup.userData = { isFallingRock: true, fallSpeed: 0 };
                } else if (type === 3) { 
                    obsGroup.userData.forceCenter = true; const safeLane = Math.floor(Math.random() * 3);
                    for(let i=0; i<3; i++) {
                        if (i !== safeLane) {
                            const lavaPit = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 0.1, 8), new THREE.MeshBasicMaterial({color: 0xff3300})); lavaPit.position.set(LANES[i], 0.05, 0); 
                            const pitHitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 1, 7.5), new THREE.MeshBasicMaterial({visible: false})); pitHitbox.position.set(LANES[i], 0.5, 0);
                            obsGroup.add(lavaPit, pitHitbox);
                        } else {
                            const bridge = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 0.1, 8), new THREE.MeshStandardMaterial({color: 0x221111})); bridge.position.set(LANES[i], 0.06, 0); obsGroup.add(bridge);
                        }
                    } obsGroup.userData.isInstaDeath = true;
                } else if (type === 4) { 
                    const smokeGrp = new THREE.Group();
                    for(let i=0; i<3; i++) { const sm = new THREE.Mesh(new THREE.SphereGeometry(1.5 + Math.random(), 8, 8), new THREE.MeshStandardMaterial({color: 0x331111, transparent: true, opacity: 0.7})); sm.position.set((Math.random()-0.5)*2, 1.5 + (Math.random()-0.5), (Math.random()-0.5)*2); smokeGrp.add(sm); }
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(3, 3, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 1.5;
                    obsGroup.add(smokeGrp, hitbox); obsGroup.userData = { isSmoke: true, isSlow: true };
                }
            } else if (selectedMap === 'fantasi') {
                if (type === 0) { 
                    const ball = new THREE.Mesh(new THREE.SphereGeometry(1.2, 16, 16), new THREE.MeshStandardMaterial({color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.8, transparent: true, opacity: 0.8})); ball.position.y = 2.5;
                    const aura = new THREE.Mesh(new THREE.SphereGeometry(1.5, 16, 16), new THREE.MeshBasicMaterial({color: 0xff00ff, transparent: true, opacity: 0.3})); aura.position.y = 2.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 10, 0.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 7.5;
                    obsGroup.add(ball, aura, hitbox);
                } else if (type === 1) { 
                    const spikesGroup = new THREE.Group();
                    for(let k=0; k<3; k++) { const spike = new THREE.Mesh(new THREE.ConeGeometry(0.5, 2.0, 4), new THREE.MeshStandardMaterial({color: 0xaa00ff, emissive: 0x5500aa, emissiveIntensity: 0.6})); spike.position.set((k-1)*0.8, 1.0, 0); spikesGroup.add(spike); }
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.5, 1.0, 1.0), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.5; obsGroup.add(spikesGroup, hitbox);
                } else if (type === 2) { 
                    const ghost = new THREE.Mesh(new THREE.DodecahedronGeometry(1.2), new THREE.MeshStandardMaterial({color: 0xffffff, emissive: 0xaaaaaa, transparent: true, opacity: 0.6})); ghost.position.y = 1.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 2.5, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 1.25;
                    obsGroup.add(ghost, hitbox); obsGroup.userData = { isSlow: true, isGhost: true }; 
                } else if (type === 3) {
                    const wall = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 4, 0.2), new THREE.MeshStandardMaterial({color: 0x2b0057, emissive: 0x110022, transparent: true, opacity: 0.8})); wall.position.y = 2;
                    const rune = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), new THREE.MeshBasicMaterial({color: 0x00e5ff})); rune.position.set(0, 2, 0.11);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 10, 0.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 5;
                    obsGroup.add(wall, rune, hitbox);
                } else if (type === 4) {
                    const dragonGrp = new THREE.Group(); const body = new THREE.Mesh(new THREE.BoxGeometry(1, 1, 2.5), new THREE.MeshStandardMaterial({color: 0xdd0000})); body.position.y = 2;
                    const wingL = new THREE.Mesh(new THREE.PlaneGeometry(2, 1), new THREE.MeshStandardMaterial({color: 0xff5500, side: THREE.DoubleSide})); wingL.rotation.x = Math.PI/2; wingL.position.set(-1.2, 2, 0);
                    const wingR = new THREE.Mesh(new THREE.PlaneGeometry(2, 1), new THREE.MeshStandardMaterial({color: 0xff5500, side: THREE.DoubleSide})); wingR.rotation.x = Math.PI/2; wingR.position.set(1.2, 2, 0);
                    dragonGrp.add(body, wingL, wingR);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(1.5, 2, 3), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 2;
                    obsGroup.add(dragonGrp, hitbox); obsGroup.userData = { isCar: true, speed: 0.6, isDragon: true }; 
                } else if (type === 5) {
                    const portal = new THREE.Mesh(new THREE.TorusGeometry(1.5, 0.3, 8, 24), new THREE.MeshBasicMaterial({color: 0x00ffaa, transparent: true, opacity: 0.8})); portal.position.y = 1.5;
                    const center = new THREE.Mesh(new THREE.CircleGeometry(1.4, 24), new THREE.MeshBasicMaterial({color: 0x0033aa, transparent: true, opacity: 0.5})); center.position.y = 1.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 3, 0.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 1.5;
                    obsGroup.add(portal, center, hitbox); obsGroup.userData.isTeleport = true; 
                } else if (type === 6) {
                    const rootGroup = new THREE.Group(); const rootMat = new THREE.MeshStandardMaterial({color: 0x220033, emissive: 0x8800ff, emissiveIntensity: 0.5, roughness: 0.9});
                    for(let j=0; j<4; j++) { const rootPart = new THREE.Mesh(new THREE.ConeGeometry(0.4, 3, 6), rootMat); rootPart.position.set((Math.random()-0.5)*1.5, 1.5, (Math.random()-0.5)*1.5); rootPart.rotation.set((Math.random()-0.5)*0.8, Math.random()*Math.PI, (Math.random()-0.5)*0.8); rootGroup.add(rootPart); }
                    const aura = new THREE.Mesh(new THREE.SphereGeometry(1.3, 8, 8), new THREE.MeshBasicMaterial({color: 0xaa00ff, transparent: true, opacity: 0.4, wireframe: true})); aura.position.y = 1.5; rootGroup.add(aura);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.5, 3, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 1.5;
                    obsGroup.add(rootGroup, hitbox); obsGroup.userData = { isCreepingRoot: true, moveDir: Math.random() > 0.5 ? 1 : -1, speedX: 0.04 + Math.random() * 0.04 }; 
                }
            } else if (selectedMap === 'kota') {
                if (type === 0) { 
                    const bar = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 0.4, 0.2), new THREE.MeshStandardMaterial({ color: 0xffaa00 })); bar.position.y = 2.5;
                    const poleMat = new THREE.MeshStandardMaterial({ color: 0x555555 }); const poleL = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 2.5, 8), poleMat); poleL.position.set(-1.4, 1.25, 0); const poleR = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 2.5, 8), poleMat); poleR.position.set(1.4, 1.25, 0);
                    const blocker = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 10, 0.5), new THREE.MeshBasicMaterial({visible: false})); blocker.position.y = 7.5; obsGroup.add(bar, poleL, poleR, blocker);
                } else if (type === 1) { 
                    const hole = new THREE.Mesh(new THREE.CylinderGeometry(1.2, 1.2, 0.05, 16), new THREE.MeshBasicMaterial({ color: 0x111111 })); hole.position.y = 0.05; 
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(1.8, 0.5, 1.8), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25; obsGroup.add(hole, hitbox);
                } else if (type === 2) { 
                    const b1 = new THREE.Mesh(new THREE.BoxGeometry(2.5, 1.2, 0.5), new THREE.MeshStandardMaterial({ color: 0xff4400 })); b1.position.y = 0.6;
                    const whiteStripe = new THREE.Mesh(new THREE.BoxGeometry(2.6, 0.3, 0.55), new THREE.MeshStandardMaterial({color: 0xffffff})); whiteStripe.position.y = 0.6;
                    obsGroup.add(b1, whiteStripe);
                } else if (type === 3) {
                    const carGroup = new THREE.Group(); const carColors = [0xdd0000, 0x0000dd, 0xdddddd, 0x222222, 0xdddd00];
                    const chassis = new THREE.Mesh(new THREE.BoxGeometry(2.4, 0.8, 4.5), new THREE.MeshStandardMaterial({color: carColors[Math.floor(Math.random() * carColors.length)], roughness: 0.3})); chassis.position.y = 0.6;
                    const cabin = new THREE.Mesh(new THREE.BoxGeometry(2, 0.8, 2.2), new THREE.MeshStandardMaterial({color: 0x111111})); cabin.position.set(0, 1.4, -0.2);
                    const headLight1 = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.3), new THREE.MeshBasicMaterial({color: 0xffffaa})); headLight1.position.set(-0.8, 0.6, 2.26); const headLight2 = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.3), new THREE.MeshBasicMaterial({color: 0xffffaa})); headLight2.position.set(0.8, 0.6, 2.26);
                    const tailLight1 = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.2), new THREE.MeshBasicMaterial({color: 0xff0000})); tailLight1.position.set(-0.8, 0.6, -2.26); tailLight1.rotation.y = Math.PI; const tailLight2 = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.2), new THREE.MeshBasicMaterial({color: 0xff0000})); tailLight2.position.set(0.8, 0.6, -2.26); tailLight2.rotation.y = Math.PI;
                    carGroup.add(chassis, cabin, headLight1, headLight2, tailLight1, tailLight2); obsGroup.userData = { isCar: true, speed: Math.random() > 0.5 ? 0.35 : 0 }; obsGroup.add(carGroup);
                } else if (type === 4) {
                    const brokenRoad = new THREE.Mesh(new THREE.CylinderGeometry(1.4, 1.4, 0.05, 12), new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.9 })); brokenRoad.position.y = 0.05;
                    const pebble1 = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.2, 0.3), new THREE.MeshStandardMaterial({color: 0x555555})); pebble1.position.set(0.5, 0.1, 0.5); const pebble2 = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.2, 0.2), new THREE.MeshStandardMaterial({color: 0x444444})); pebble2.position.set(-0.6, 0.1, -0.4);
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.2, 0.5, 2.2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25;
                    obsGroup.add(brokenRoad, pebble1, pebble2, hitbox); obsGroup.userData.isSlow = true; 
                } else if (type === 5) {
                    const dirt = new THREE.Mesh(new THREE.DodecahedronGeometry(1.2), new THREE.MeshStandardMaterial({color: 0x5c4033, roughness: 1})); dirt.position.y = 0.2; dirt.scale.y = 0.5;
                    const boardMat = new THREE.MeshStandardMaterial({color: 0x8b5a2b}); 
                    const board1 = new THREE.Mesh(new THREE.BoxGeometry(2, 0.1, 0.4), boardMat); board1.position.set(0.2, 0.6, 0); board1.rotation.y = 0.5; board1.rotation.z = 0.2;
                    const board2 = new THREE.Mesh(new THREE.BoxGeometry(1.8, 0.1, 0.4), boardMat); board2.position.set(-0.3, 0.4, 0.5); board2.rotation.y = -0.3;
                    const coneMat = new THREE.MeshStandardMaterial({color: 0xff4400}); const cone1 = new THREE.Mesh(new THREE.ConeGeometry(0.3, 1, 8), coneMat); cone1.position.set(-1, 0.5, -0.5); const cone2 = new THREE.Mesh(new THREE.ConeGeometry(0.3, 1, 8), coneMat); cone2.position.set(1, 0.5, 0.5);
                    const blocker = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 3, 1), new THREE.MeshBasicMaterial({visible: false})); blocker.position.y = 1.5;
                    obsGroup.add(dirt, board1, board2, cone1, cone2, blocker);
                } else if (type === 6) {
                    const pole = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, 6, 8), new THREE.MeshStandardMaterial({color: 0x555555})); pole.position.y = 3;
                    const base = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 1.5, 0.8), new THREE.MeshStandardMaterial({color: 0x222222})); base.position.y = 0.75;
                    const colors = [0xff0055, 0x00ddff, 0xaa00ff, 0x00ff00, 0xffaa00]; const screenColor = colors[Math.floor(Math.random() * colors.length)];
                    const screen = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH + 0.5, 3.5, 0.4), new THREE.MeshStandardMaterial({color: screenColor, emissive: screenColor, emissiveIntensity: 0.6})); screen.position.y = 6.5;
                    const frame = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH + 0.7, 3.7, 0.5), new THREE.MeshStandardMaterial({color: 0x111111})); frame.position.y = 6.5;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 10, 1), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 5;
                    obsGroup.add(pole, base, frame, screen, hitbox);
                }
            } else if (selectedMap === 'sungai') {
                if (type === 0) { 
                    const bambooMat = new THREE.MeshStandardMaterial({ color: 0x556b2f, roughness: 0.8 }); 
                    const bamboo = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, LANE_WIDTH + 1, 8), bambooMat); bamboo.rotation.z = Math.PI/2; bamboo.position.set(0, 2.5, 0); 
                    const pillarL = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 2.6, 8), bambooMat); pillarL.position.set(-1.5, 1.3, 0); const pillarR = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 2.6, 8), bambooMat); pillarR.position.set(1.5, 1.3, 0);
                    const blocker = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 10, 0.5), new THREE.MeshBasicMaterial({visible: false})); blocker.position.y = 7.5; obsGroup.add(bamboo, pillarL, pillarR, blocker);
                } else if (type === 1) { 
                    const fullWidth = LANE_WIDTH * 3; const bridgeMat = new THREE.MeshStandardMaterial({ color: 0x4a3219, roughness: 0.9 });
                    const plankStart = new THREE.Mesh(new THREE.BoxGeometry(fullWidth, 0.2, 1), bridgeMat); plankStart.position.set(0, 0.1, 1.5); 
                    const plankEnd = new THREE.Mesh(new THREE.BoxGeometry(fullWidth, 0.2, 1), bridgeMat); plankEnd.position.set(0, 0.1, -1.5); 
                    const water = new THREE.Mesh(new THREE.BoxGeometry(fullWidth, 0.3, 2), new THREE.MeshStandardMaterial({ color: 0x336699, transparent: true, opacity: 0.8 })); water.position.y = 0.15;
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(fullWidth - 0.2, 1, 1.5), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.5;
                    obsGroup.add(plankStart, plankEnd, water, hitbox); obsGroup.userData.forceCenter = true;
                } else if (type === 2) { 
                    if (Math.random() > 0.5) { const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(1.6), new THREE.MeshStandardMaterial({ color: 0x445555, roughness: 0.2 })); rock.position.y = 0.8; obsGroup.add(rock); } 
                    else { const log = new THREE.Mesh(new THREE.CylinderGeometry(0.8, 0.8, 2.5, 8), new THREE.MeshStandardMaterial({color: 0x2a1a10})); log.rotation.z = Math.PI/2; log.position.y = 0.8; obsGroup.add(log); }
                } else if (type === 3) {
                    const mud = new THREE.Mesh(new THREE.CylinderGeometry(1.4, 1.4, 0.1, 16), new THREE.MeshStandardMaterial({ color: 0x1f1209, roughness: 1 })); mud.position.y = 0.05; 
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2, 0.5, 2), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 0.25; obsGroup.add(mud, hitbox); obsGroup.userData.isSlow = true; 
                } else if (type === 4) {
                    for (let i = 0; i < 5; i++) { const bamboo = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 8, 8), new THREE.MeshStandardMaterial({ color: 0x556b2f, roughness: 0.8 })); bamboo.position.set((i - 2) * 0.5, 4, (Math.random() - 0.5) * 0.5); bamboo.rotation.x = (Math.random() - 0.5) * 0.2; bamboo.rotation.z = (Math.random() - 0.5) * 0.2; obsGroup.add(bamboo); }
                    const hitbox = new THREE.Mesh(new THREE.BoxGeometry(2.5, 10, 1), new THREE.MeshBasicMaterial({visible: false})); hitbox.position.y = 5; obsGroup.add(hitbox);
                }
            } else if (selectedMap === 'hutan') {
                if (type === 0) { 
                    const barMat = new THREE.MeshStandardMaterial({ color: 0x3d2616, roughness: 1 }); const bar = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, LANE_WIDTH + 1, 8), barMat); bar.rotation.z = Math.PI/2; bar.position.y = 2.5;
                    const pillarL = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 2.5, 8), barMat); pillarL.position.set(-1.5, 1.25, 0); const pillarR = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.2, 2.5, 8), barMat); pillarR.position.set(1.5, 1.25, 0);
                    const blocker = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH, 10, 0.5), new THREE.MeshBasicMaterial({visible: false})); blocker.position.y = 7.5; obsGroup.add(bar, pillarL, pillarR, blocker);
                } else if (type === 1) { 
                    if (Math.random() > 0.5) { const mesh = new THREE.Mesh(new THREE.CylinderGeometry(0.6, 0.6, LANE_WIDTH - 0.2, 8), new THREE.MeshStandardMaterial({ color: 0x3d2616, roughness: 1 })); mesh.rotation.z = Math.PI/2; mesh.position.y = 0.5; obsGroup.add(mesh); } 
                    else { const mesh = new THREE.Mesh(new THREE.BoxGeometry(LANE_WIDTH - 0.2, 0.6, 0.8), new THREE.MeshStandardMaterial({ color: 0x2a1a10, roughness: 1 })); mesh.position.y = 0.3; obsGroup.add(mesh); }
                } else if (type === 2) { 
                    if (Math.random() > 0.5) { const rock = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5), new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.9 })); rock.position.y = 1.0; obsGroup.add(rock); } 
                    else { obsGroup.add(createVariedTree(0.8, true)); }
                } else if (type === 3) {
                    const bushMat = new THREE.MeshStandardMaterial({ color: 0x113311, roughness: 1 }); const bushGroup = new THREE.Group();
                    const bL = new THREE.Mesh(new THREE.DodecahedronGeometry(1.0), bushMat); bL.position.set(-1.1, 0.8, 0); bL.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
                    const bR = new THREE.Mesh(new THREE.DodecahedronGeometry(1.0), bushMat); bR.position.set(1.1, 0.8, 0); bR.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
                    const bTop = new THREE.Mesh(new THREE.DodecahedronGeometry(1.5), bushMat); bTop.position.set(0, 2.7, 0); bTop.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
                    bushGroup.add(bL, bR, bTop); const blocker = new THREE.Mesh(new THREE.BoxGeometry(2.8, 8, 1.5), new THREE.MeshBasicMaterial({visible: false})); blocker.position.y = 5.5; 
                    obsGroup.add(bushGroup, blocker); obsGroup.userData.isSlow = true; 
                }
            } else if (selectedMap === 'desa') {
                if (type === 0) { 
